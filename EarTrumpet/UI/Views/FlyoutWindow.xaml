<Window x:Class="EarTrumpet.UI.Views.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Event="clr-namespace:EarTrumpet.Extensions.EventBinding"
        xmlns:Theme="clr-namespace:EarTrumpet.UI.Themes"
        xmlns:b="clr-namespace:EarTrumpet.UI.Behaviors"
        xmlns:ctl="clr-namespace:EarTrumpet.UI.Controls"
        xmlns:resx="clr-namespace:EarTrumpet.Properties"
        xmlns:views="clr-namespace:EarTrumpet.UI.Views"
        xmlns:vm="clr-namespace:EarTrumpet.UI.ViewModels"
        Title="EarTrumpet"
        Width="{StaticResource WindowAndItemSize}"
        Theme:Brush.Foreground="Text"
        Theme:Options.Scope="Flyout"
        Theme:Options.Source="System"
        b:FrameworkElementEx.DisplaySettingsChanged="{Binding DisplaySettingsChanged}"
        b:FrameworkElementEx.FlowDirection="Auto"
        AllowsTransparency="True"
        Background="Transparent"
        Closing="{Event:Binding OnClosing}"
        Deactivated="{Event:Binding OnDeactivated}"
        Icon="{Binding Source={StaticResource EarTrumpetIconLight}}"
        PreviewKeyDown="{Event:Binding OnPreviewKeyDown}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        WindowStyle="None">
    <Window.Resources>
        <views:FormFactorToIconConverter x:Key="FormFactorToIconConverter"/>
        <views:EnumeratorToBadgeConverter x:Key="EnumeratorToBadgeConverter"/>
        <views:ProgressBarWidthConverter x:Key="ProgressBarWidthConverter"/>

        <Style x:Key="ExpandCollapseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Theme:Brush.Foreground" Value="Theme=Text, HighContrast=ControlText" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource Windows10FocusVisualStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="true">
                    <Setter Property="Theme:Brush.Background" Value="Theme=#20FFFFFF, HighContrast=Highlight" />
                    <Setter Property="Theme:Brush.Foreground" Value="Theme=ApplicationText{Theme}Theme, HighContrast=HighlightText" />
                </Trigger>
                <Trigger Property="IsPressed" Value="true">
                    <Setter Property="Theme:Brush.Background" Value="Theme=#2FFFFFFF, HighContrast=Highlight" />
                    <Setter Property="Theme:Brush.Foreground" Value="Theme=ApplicationText{Theme}Theme, HighContrast=HighlightText" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True" />
                        <Condition Property="Theme:OS.IsWindows11" Value="True" />
                    </MultiTrigger.Conditions>
                    <MultiTrigger.Setters>
                        <Setter Property="Theme:Brush.Background" Value="Theme=Control{Theme}SelectHighlightHover, HighContrast=Highlight" />
                        <Setter Property="Theme:Brush.Foreground" Value="Theme=ApplicationText{Theme}Theme, HighContrast=HighlightText" />
                    </MultiTrigger.Setters>
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsPressed" Value="True" />
                        <Condition Property="Theme:OS.IsWindows11" Value="True" />
                    </MultiTrigger.Conditions>
                    <MultiTrigger.Setters>
                        <Setter Property="Theme:Brush.Background" Value="Theme=Control{Theme}SelectHighlightHover/0.20, HighContrast=Highlight" />
                        <Setter Property="Theme:Brush.Foreground" Value="Theme=ApplicationText{Theme}Theme, HighContrast=HighlightText" />
                    </MultiTrigger.Setters>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="{x:Type ScrollViewer}"
               BasedOn="{StaticResource {x:Type ScrollViewer}}"
               TargetType="{x:Type ScrollViewer}">
            <Setter Property="CanContentScroll" Value="True" />
            <Setter Property="PanningMode" Value="VerticalOnly" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <DataTemplate DataType="{x:Type vm:DeviceViewModel}">
            <views:DeviceView Width="{StaticResource WindowAndItemSize}"
                              Device="{Binding}"
                              IsDisplayNameVisible="{Binding IsDisplayNameVisible}" />
        </DataTemplate>

        <!-- ═══ DEVICE PICKER ITEM TEMPLATE ═══ -->
        <DataTemplate x:Key="DevicePickerItemTemplate">
            <Border Padding="14,9" Margin="0" CornerRadius="6"
                    Background="Transparent" Cursor="Hand"
                    MouseLeftButtonUp="DeviceRow_Click" Tag="{Binding}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Theme:Brush.Background" Value="Theme=#20FFFFFF, HighContrast=Highlight"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Name + driver -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="4,0,0,0">
                        <TextBlock Text="{Binding DeviceDescription}"
                                   FontSize="13" FontWeight="Medium" Opacity="0.9"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="StatusText" FontSize="10" Opacity="0.3" Margin="0,2,0,0" Text="{Binding InterfaceName}"/>
                    </StackPanel>

                    <!-- Radio dot -->
                    <Grid Grid.Column="1" Width="22" VerticalAlignment="Center" Margin="8,0,0,0">
                        <Ellipse x:Name="RadioOuter" Width="18" Height="18"
                                 Stroke="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" StrokeThickness="1.5" Fill="Transparent" Opacity="0.4"/>
                        <Ellipse x:Name="RadioSelectedOuter" Width="18" Height="18"
                                 Fill="#FF3B9EFF" Visibility="Collapsed"/>
                        <Ellipse x:Name="RadioSelectedInner" Width="7" Height="7"
                                 Fill="White" Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsDefault}" Value="True">
                    <Setter TargetName="RadioOuter" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="RadioSelectedOuter" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="RadioSelectedInner" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="StatusText" Property="Opacity" Value="0.45"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Category group template (kept for potential future use) -->
    </Window.Resources>
    <Grid x:Name="LayoutRoot">
        <!-- Pin button overlay -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,6,8,0" Padding="6,4" CornerRadius="4"
                Cursor="Hand" Background="Transparent" Panel.ZIndex="50"
                MouseLeftButtonUp="PinButton_Click">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Devices.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Theme:Brush.Background" Value="Theme=#20FFFFFF, HighContrast=Highlight"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding PinGlyph}" FontFamily="Segoe MDL2 Assets"
                       FontSize="11" Opacity="0.3"/>
        </Border>
        <DockPanel Name="BaseVisual" LastChildFill="True" Theme:Brush.Background="FlyoutBackground">

            <!-- ═══ GLOBAL MIX (anchored bottom) ═══ -->
            <Border DockPanel.Dock="Bottom" Padding="4,6,4,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Devices.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Grid Margin="14,0,14,2">
                        <TextBlock Text="Global Mix" FontSize="12" FontWeight="Medium"
                                   Opacity="0.55" HorizontalAlignment="Left"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.35">
                            <Run Text="{Binding DevicePicker.MasterVolume, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                    </Grid>
                    <Grid Height="{DynamicResource Mutable_DeviceItemCellHeight}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="46"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE993;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" Opacity="0.3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <ctl:VolumeSlider Grid.Column="1"
                                         Value="{Binding DevicePicker.MasterVolume, Mode=TwoWay}"
                                         PeakValue1="{Binding Devices[0].PeakValue1, FallbackValue=0}"
                                         PeakValue2="{Binding Devices[0].PeakValue2, FallbackValue=0}"/>
                        <TextBlock Grid.Column="2" Text="&#xE995;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" Opacity="0.3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ SCROLLABLE CONTENT ═══ -->
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <StackPanel Name="ContentGrid" VerticalAlignment="Top" Background="#01000000">
                <!-- No devices message -->
                <Border VerticalAlignment="Center" Theme:Brush.Background="FlyoutBackground">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Devices.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Margin="{StaticResource NoItemsPaneMargin}"
                               HorizontalAlignment="Center"
                               FontSize="{StaticResource {x:Static SystemFonts.MessageFontSizeKey}}"
                               Text="{x:Static resx:Resources.NoDevicesPanelContent}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Pin button moved to overlay -->

                <!-- ═══ NOW PLAYING — premium, color from cover ═══ -->
                <Border x:Name="MediaCard" Margin="0,0,0,4" CornerRadius="0" ClipToBounds="True">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DevicePicker.HasMedia}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Album art -->
                                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="6"
                                        Margin="0,0,10,0" Opacity="0.9" ClipToBounds="True">
                                    <Image Source="{Binding DevicePicker.MediaThumbnail}"
                                           Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Right: compact info + progress + controls -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DevicePicker.MediaTitle}"
                                               FontSize="13" FontWeight="SemiBold" Opacity="0.95"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11" Opacity="0.45" Margin="0,1,0,0"
                                               TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding DevicePicker.MediaArtist, Mode=OneWay}"/>
                                    </TextBlock>
                                    <!-- Progress bar -->
                                    <Grid Margin="0,6,0,0" Height="2.5">
                                        <Border CornerRadius="1.25" Opacity="0.12" Theme:Brush.Background="Text"/>
                                        <Border CornerRadius="1.25" Opacity="0.8" Theme:Brush.Background="Text" HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                                    <Binding Path="DevicePicker.MediaPosition"/>
                                                    <Binding Path="DevicePicker.MediaDuration"/>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>
                                    <!-- Timestamps + controls -->
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DevicePicker.MediaPositionText}"
                                                   FontSize="10" Opacity="0.35" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Border Padding="7,2" Cursor="Hand" Background="Transparent"
                                                    MouseLeftButtonUp="PreviousTrack_Click">
                                                <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12" Opacity="0.55" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Padding="8,2" Cursor="Hand" Background="Transparent"
                                                    MouseLeftButtonUp="PlayPause_Click">
                                                <TextBlock Text="{Binding DevicePicker.PlayPauseGlyph}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="17" Opacity="0.9" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Padding="7,2" Cursor="Hand" Background="Transparent"
                                                    MouseLeftButtonUp="NextTrack_Click">
                                                <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12" Opacity="0.55" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding DevicePicker.MediaDurationText}"
                                                   FontSize="10" Opacity="0.35" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                </Border>

                <!-- ═══ DEVICE LIST (collapsible, animated height) ═══ -->
                <Border x:Name="DeviceListContainer" ClipToBounds="True" Height="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Devices.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ItemsControl x:Name="DeviceListItems"
                                  ItemsSource="{Binding DevicePicker.AllPlaybackDevices}" Focusable="False"
                                  ItemTemplate="{StaticResource DevicePickerItemTemplate}"/>
                </Border>

                <!-- Toggle header (BELOW the list = bottom-to-top feel) -->
                <Border Margin="4,0,4,2" Padding="14,9" CornerRadius="6" Cursor="Hand"
                        MouseLeftButtonUp="ToggleDeviceList_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Devices.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Theme:Brush.Background" Value="Theme=#15FFFFFF, HighContrast=Highlight"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding DevicePicker.SelectedDevice.DeviceDescription, FallbackValue='Speakers'}"
                                   FontSize="12" FontWeight="Medium" Opacity="0.55" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   Opacity="0.25" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE70E;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DevicePicker.IsDeviceListExpanded}" Value="False">
                                            <Setter Property="Text" Value="&#xE70D;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Separator -->
                <Border Height="1" Opacity="0.08" Theme:Brush.Background="Text" Margin="12,4,12,2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Devices.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- ═══ APPLICATION VOLUME MIX header ═══ -->
                <TextBlock Text="APPLICATION VOLUME MIX"
                           FontSize="11" FontWeight="Bold" Opacity="0.35"
                           Margin="16,12,16,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Devices.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- ═══ APP SLIDERS ═══ -->
                <ItemsControl Name="DevicesList"
                              FocusVisualStyle="{x:Null}"
                              IsTabStop="False"
                              ItemsSource="{Binding Devices}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Devices.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                </ItemsControl>

                <!-- Update available banner -->
                <Border x:Name="UpdateBanner"
                        Cursor="Hand"
                        MouseLeftButtonUp="UpdateBanner_Click"
                        CornerRadius="6"
                        Margin="8,4,8,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border CornerRadius="6" ClipToBounds="True" Background="#10808080">
                        <Border x:Name="UpdateBannerInner"
                                CornerRadius="5" BorderBrush="#20808080" BorderThickness="1"
                                Padding="12,8" Opacity="0">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="UpdateBannerInner"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE735;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#70B8FF" Offset="0" />
                                            <GradientStop Color="#A78BFA" Offset="1" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding UpdateText}" FontSize="12"
                                           FontWeight="Medium" VerticalAlignment="Center" Opacity="0.8" />
                                <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.4" />
                            </Grid>
                        </Border>
                    </Border>
                </Border>
            </StackPanel>
            </ScrollViewer>
        </DockPanel>
        <Border Name="LightDismissBorder"
                Theme:Brush.Background="Background"
                PreviewMouseDown="{Event:Binding OnLightDismissBorderPreviewMouseDown}">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Dialog.IsVisible}" Value="True" />
                                <Condition Binding="{Binding Source={StaticResource ThemeManager}, Path=AnimationsEnabled}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="EnterLightDismiss_AnimationsOff" />
                                <StopStoryboard BeginStoryboardName="ExitLightDismiss_AnimationsOff" />
                                <BeginStoryboard Name="EnterLightDismiss_AnimationsOn">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="00:00:00.15" />
                                        <ObjectAnimationUsingKeyFrames BeginTime="00:00:00" Storyboard.TargetProperty="(UIElement.Visibility)">
                                            <DiscreteObjectKeyFrame KeyTime="00:00:00" Value="{x:Static Visibility.Visible}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiDataTrigger.EnterActions>
                            <MultiDataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="EnterLightDismiss_AnimationsOff" />
                                <StopStoryboard BeginStoryboardName="ExitLightDismiss_AnimationsOff" />
                                <BeginStoryboard Name="ExitLightDismiss_AnimationsOn">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0" Duration="00:00:00.15" />
                                        <ObjectAnimationUsingKeyFrames BeginTime="00:00:00" Storyboard.TargetProperty="(UIElement.Visibility)">
                                            <DiscreteObjectKeyFrame KeyTime="00:00:00.15" Value="{x:Static Visibility.Collapsed}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiDataTrigger.ExitActions>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Dialog.IsVisible}" Value="True" />
                                <Condition Binding="{Binding Source={StaticResource ThemeManager}, Path=AnimationsEnabled}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="EnterLightDismiss_AnimationsOn" />
                                <StopStoryboard BeginStoryboardName="ExitLightDismiss_AnimationsOn" />
                                <BeginStoryboard Name="EnterLightDismiss_AnimationsOff">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames BeginTime="00:00:00" Storyboard.TargetProperty="(UIElement.Visibility)">
                                            <DiscreteObjectKeyFrame KeyTime="00:00:00" Value="{x:Static Visibility.Visible}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiDataTrigger.EnterActions>
                            <MultiDataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="EnterLightDismiss_AnimationsOn" />
                                <StopStoryboard BeginStoryboardName="ExitLightDismiss_AnimationsOn" />
                                <BeginStoryboard Name="ExitLightDismiss_AnimationsOff">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames BeginTime="00:00:00" Storyboard.TargetProperty="(UIElement.Visibility)">
                                            <DiscreteObjectKeyFrame KeyTime="00:00:00" Value="{x:Static Visibility.Collapsed}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiDataTrigger.ExitActions>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Margin="0,0,0,14">
                <Border.Effect>
                    <BlurEffect KernelType="Gaussian"
                                Radius="{StaticResource WindowBlurRadius}"
                                RenderingBias="Performance" />
                </Border.Effect>
                <Border.Background>
                    <VisualBrush AlignmentX="Left"
                                 AlignmentY="Top"
                                 Stretch="UniformToFill"
                                 Visual="{Binding ElementName=BaseVisual}" />
                </Border.Background>
            </Border>
        </Border>
        <ctl:AppPopup IsOpen="{Binding Dialog.IsVisible, Mode=TwoWay}"
                      PlacementTarget="{Binding Dialog.Source}"
                      Style="{StaticResource AppPopup}">
            <ContentControl Content="{Binding Dialog.Focused}" />
        </ctl:AppPopup>
    </Grid>
</Window>
