<Window x:Class="EarTrumpet.UI.Views.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Theme="clr-namespace:EarTrumpet.UI.Themes"
        Title="Command Palette"
        Width="460"
        SizeToContent="Height"
        Theme:Options.Source="App"
        Background="{DynamicResource Background}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True">
    <Window.Resources>
        <Style x:Key="PaletteListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3CFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#55FFFFFF"
            BorderThickness="1"
            CornerRadius="8"
            Background="#E6202020"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Search box -->
            <TextBox x:Name="SearchBox"
                     Grid.Row="0"
                     Margin="12,12,12,6"
                     Padding="8,6"
                     FontSize="14"
                     Background="#33FFFFFF"
                     Foreground="White"
                     CaretBrush="White"
                     BorderThickness="0"
                     TextChanged="SearchBox_TextChanged"
                     PreviewKeyDown="SearchBox_PreviewKeyDown" />

            <!-- Separator -->
            <Border Grid.Row="1"
                    Height="1"
                    Margin="12,0"
                    Background="#33FFFFFF" />

            <!-- Results list -->
            <ListBox x:Name="ResultsList"
                     Grid.Row="2"
                     MaxHeight="340"
                     Margin="4,6,4,8"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource PaletteListItem}"
                     MouseDoubleClick="ResultsList_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="White"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Shortcut}"
                                       Foreground="#88FFFFFF"
                                       FontSize="11"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
