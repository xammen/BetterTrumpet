<Window x:Class="EarTrumpet.UI.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resx="clr-namespace:EarTrumpet.Properties"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        Title="{x:Static resx:Resources.OnboardingWindowTitle}"
        Width="760" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/UI/Controls/OnboardingComponents.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource OnboardingBg}"
            BorderBrush="{StaticResource OnboardingBorder}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="3"
                    CornerRadius="12"
                    IsHitTestVisible="False"
                    Opacity="0.42">
                <Border.Background>
                    <RadialGradientBrush x:Name="AmbientGradient" GradientOrigin="0.18,0.06" Center="0.18,0.06" RadiusX="0.72" RadiusY="0.72">
                        <GradientStop Color="#1C3B9EFF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <Grid Grid.Row="0" Margin="30,24,30,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="BetterTrumpet"
                               Foreground="{StaticResource OnboardingText}"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StepLabel}"
                               Foreground="{StaticResource OnboardingTextSubtle}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding CurrentTitle}"
                           Foreground="{StaticResource OnboardingTextMuted}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="1"
                      Grid.ColumnSpan="2"
                      Height="3"
                      Margin="0,18,0,0"
                      Background="{StaticResource OnboardingTrack}">
                    <Border x:Name="ProgressBar"
                            Background="{StaticResource OnboardingTrackFill}"
                            HorizontalAlignment="Left"
                            CornerRadius="0,2,2,0">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ProgressScale" ScaleX="0.1667" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>
                            <Point X="0" Y="0.5"/>
                        </Border.RenderTransformOrigin>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="30,0,30,18">
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                    </Style>
                </Grid.Resources>

                <Grid x:Name="Page1" Visibility="{Binding IsPage1, Converter={StaticResource BoolVis}}">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="Page1Transform"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" MaxWidth="520">
                        <TextBlock Text="{x:Static resx:Resources.OnboardingAudioOutput}"
                                   Foreground="{StaticResource OnboardingText}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{x:Static resx:Resources.OnboardingSubtitleAudio}"
                                   Foreground="{StaticResource OnboardingTextMuted}"
                                   FontSize="14"
                                   LineHeight="22"
                                   Margin="0,0,0,20"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Text="{x:Static resx:Resources.OnboardingNoDevices}"
                               Visibility="{Binding HasNoDevices, Converter={StaticResource BoolVis}}"
                               Foreground="{StaticResource OnboardingTextMuted}"
                               FontSize="13"
                               Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1" MaxHeight="350" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AudioDevices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource OnboardingChoiceCard}"
                                            Margin="0,0,0,10"
                                            MouseLeftButtonDown="DeviceCard_Click"
                                            Tag="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="36"
                                                    Height="36"
                                                    CornerRadius="7"
                                                    Background="{StaticResource OnboardingSurfaceElevated}"
                                                    Margin="0,0,14,0">
                                                <TextBlock Text="♪"
                                                           Foreground="{StaticResource OnboardingAccent}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{StaticResource OnboardingText}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{x:Static resx:Resources.OnboardingDeviceConfigured}"
                                                           Foreground="{StaticResource OnboardingTextMuted}"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="✓"
                                                       Foreground="{StaticResource OnboardingAccent}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsDefault, Converter={StaticResource BoolVis}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="Page2" Visibility="{Binding IsPage2, Converter={StaticResource BoolVis}}">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="Page2Transform"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{x:Static resx:Resources.OnboardingAppearance}"
                               Foreground="{StaticResource OnboardingText}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1"
                               Text="{x:Static resx:Resources.OnboardingSubtitleAppearance}"
                               Foreground="{StaticResource OnboardingTextMuted}"
                               FontSize="14"
                               LineHeight="22"
                               Margin="0,0,0,22"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource OnboardingCardButton}"
                                Margin="0,0,12,0"
                                Tag="0"
                                Click="ThemeCard_Click">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingSystemTheme}"
                                               Foreground="{StaticResource OnboardingText}"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingSystemThemeDesc}"
                                               Foreground="{StaticResource OnboardingTextMuted}"
                                               FontSize="13"
                                               LineHeight="20"
                                               Margin="0,8,0,18"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1"
                                           Text="{x:Static resx:Resources.OnboardingRecommendedBadge}"
                                           Foreground="{StaticResource OnboardingAccent}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Bottom"
                                           Visibility="{Binding IsSystemThemeSelected, Converter={StaticResource BoolVis}}"/>
                            </Grid>
                        </Button>

                        <Button Grid.Column="1"
                                Style="{StaticResource OnboardingCardButton}"
                                Margin="12,0,0,0"
                                Tag="1"
                                Click="ThemeCard_Click">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingCustomTheme}"
                                               Foreground="{StaticResource OnboardingText}"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingCustomThemeDesc}"
                                               Foreground="{StaticResource OnboardingTextMuted}"
                                               FontSize="13"
                                               LineHeight="20"
                                               Margin="0,8,0,18"/>
                                    <Border Height="42"
                                            CornerRadius="8"
                                            Background="{StaticResource OnboardingSurfaceElevated}"
                                            BorderBrush="{StaticResource OnboardingBorderSoft}"
                                            BorderThickness="1">
                                        <Grid Margin="12,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Height="6" CornerRadius="3" Background="{StaticResource OnboardingAccent}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Height="6" CornerRadius="3" Background="#4ED5A8" VerticalAlignment="Center" Margin="8,0"/>
                                            <Border Grid.Column="2" Height="6" CornerRadius="3" Background="#303744" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Row="1"
                                           Text="{x:Static resx:Resources.OnboardingCustomThemeNote}"
                                           Foreground="{StaticResource OnboardingAccent}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Bottom"
                                           Visibility="{Binding IsCustomThemeSelected, Converter={StaticResource BoolVis}}"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Grid>

                <Grid x:Name="Page3" Visibility="{Binding IsPage3, Converter={StaticResource BoolVis}}">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="Page3Transform"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{x:Static resx:Resources.OnboardingPrivacy}"
                               Foreground="{StaticResource OnboardingText}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1"
                               Text="{x:Static resx:Resources.OnboardingSubtitlePrivacy}"
                               Foreground="{StaticResource OnboardingTextMuted}"
                               FontSize="14"
                               LineHeight="22"
                               Margin="0,0,0,20"/>

                    <Grid Grid.Row="2">
                        <StackPanel MaxWidth="560">
                            <Border Style="{StaticResource OnboardingCard}" Padding="18" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static resx:Resources.OnboardingTelemetryValueTitle}"
                                                       Foreground="{StaticResource OnboardingText}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Static resx:Resources.OnboardingTelemetryValueDesc}"
                                                       Foreground="{StaticResource OnboardingTextMuted}"
                                                       FontSize="12"
                                                       LineHeight="18"
                                                       Margin="0,6,16,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding IsTelemetryEnabled}"
                                                  Style="{StaticResource OnboardingCheckBox}"
                                                  VerticalAlignment="Top"/>
                                    </Grid>

                                    <Border Margin="0,14,0,0"
                                            Background="{StaticResource OnboardingSurfaceElevated}"
                                            BorderBrush="{StaticResource OnboardingBorderSoft}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="14"
                                            Visibility="{Binding IsTelemetryDisableConfirmationVisible, Converter={StaticResource BoolVis}}">
                                        <StackPanel>
                                            <TextBlock Text="{x:Static resx:Resources.OnboardingTelemetryConfirmTitle}"
                                                       Foreground="{StaticResource OnboardingText}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Static resx:Resources.OnboardingTelemetryConfirmDesc}"
                                                       Foreground="{StaticResource OnboardingTextMuted}"
                                                       FontSize="12"
                                                       LineHeight="18"
                                                       Margin="0,6,0,12"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="{x:Static resx:Resources.OnboardingTelemetryDisableAnyway}"
                                                        Command="{Binding ConfirmDisableTelemetryCommand}"
                                                        Style="{StaticResource OnboardingDangerButton}"
                                                        Margin="0,0,8,0"/>
                                                <Button Content="{x:Static resx:Resources.OnboardingTelemetryKeepEnabled}"
                                                        Command="{Binding KeepTelemetryEnabledCommand}"
                                                        Style="{StaticResource OnboardingPrimaryButton}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <CheckBox Content="{x:Static resx:Resources.OnboardingLaunchAtStartup}"
                                      IsChecked="{Binding RunAtStartup}"
                                      Style="{StaticResource OnboardingCheckBox}"
                                      Margin="4,6,0,0"/>
                            <TextBlock Text="{x:Static resx:Resources.OnboardingLaunchAtStartupDesc}"
                                       Foreground="{StaticResource OnboardingTextMuted}"
                                       FontSize="12"
                                       Margin="32,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid x:Name="Page4" Visibility="{Binding IsPage4, Converter={StaticResource BoolVis}}">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="Page4Transform"/>
                    </Grid.RenderTransform>
                    <StackPanel VerticalAlignment="Center" MaxWidth="560">
                        <TextBlock Text="{x:Static resx:Resources.OnboardingAllReady}"
                                   Foreground="{StaticResource OnboardingText}"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{x:Static resx:Resources.OnboardingSetupReadyDesc}"
                                   Foreground="{StaticResource OnboardingTextMuted}"
                                   FontSize="15"
                                   LineHeight="23"
                                   Margin="0,0,0,22"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource OnboardingCard}" Padding="16" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="✓" Foreground="{StaticResource OnboardingAccent}" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingDeviceConfigured}" Foreground="{StaticResource OnboardingText}" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource OnboardingCard}" Padding="16" Margin="8,0">
                                <StackPanel>
                                    <TextBlock Text="✓" Foreground="{StaticResource OnboardingAccent}" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingAppearanceChosen}" Foreground="{StaticResource OnboardingText}" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource OnboardingCard}" Padding="16" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="✓" Foreground="{StaticResource OnboardingAccent}" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingPrivacyConfigured}" Foreground="{StaticResource OnboardingText}" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="{x:Static resx:Resources.OnboardingTrayAccessDesc}"
                                   Foreground="{StaticResource OnboardingTextSubtle}"
                                   FontSize="12"
                                   LineHeight="18"
                                   Margin="0,20,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="Page5" Visibility="{Binding IsPage5, Converter={StaticResource BoolVis}}">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="Page5Transform"/>
                    </Grid.RenderTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource OnboardingSurface}"
                            BorderBrush="{StaticResource OnboardingBorderSoft}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            VerticalAlignment="Center">
                        <Image Height="330"
                               Stretch="Uniform"
                               gif:AnimationBehavior.SourceUri="pack://application:,,,/Assets/TrayPin.gif"
                               gif:AnimationBehavior.RepeatBehavior="Forever"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="34,0,0,0">
                        <TextBlock Text="{x:Static resx:Resources.OnboardingPinTitle}"
                                   Foreground="{StaticResource OnboardingText}"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   LineHeight="36"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{x:Static resx:Resources.OnboardingPinDesc}"
                                   Foreground="{StaticResource OnboardingTextMuted}"
                                   FontSize="14"
                                   LineHeight="22"
                                   MaxWidth="300"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Margin="30,0,30,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{x:Static resx:Resources.OnboardingSkip}"
                        Style="{StaticResource OnboardingGhostButton}"
                        Click="Skip_Click"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border x:Name="Dot0" Width="7" Height="7" CornerRadius="4" Margin="5"/>
                    <Border x:Name="Dot1" Width="7" Height="7" CornerRadius="4" Margin="5"/>
                    <Border x:Name="Dot2" Width="7" Height="7" CornerRadius="4" Margin="5"/>
                    <Border x:Name="Dot3" Width="7" Height="7" CornerRadius="4" Margin="5"/>
                    <Border x:Name="Dot4" Width="7" Height="7" CornerRadius="4" Margin="5"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{x:Static resx:Resources.OnboardingBack}"
                            Style="{StaticResource OnboardingGhostButton}"
                            Click="Back_Click"
                            Visibility="{Binding CanGoBack, Converter={StaticResource BoolVis}}"
                            Margin="0,0,10,0"/>
                    <Button Content="{Binding NextButtonText}"
                            Style="{StaticResource OnboardingPrimaryButton}"
                            Click="Next_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
