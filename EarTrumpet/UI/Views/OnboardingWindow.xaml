<Window x:Class="EarTrumpet.UI.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resx="clr-namespace:EarTrumpet.Properties"
        Title="BetterTrumpet"
        Width="580" Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/EarTrumpet;component/UI/Controls/OnboardingComponents.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- ═══ SHELL ═══ -->
    <Border CornerRadius="12" ClipToBounds="True"
            Background="{StaticResource Onboarding.SurfaceBrush}"
            BorderBrush="#08FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- ═══ TOP: Progress bar + Drag area ═══ -->
            <Grid Grid.Row="0">
                <!-- Progress bar -->
                <Border Height="3" VerticalAlignment="Top" Background="#08FFFFFF">
                    <Border x:Name="ProgressBar" Background="{StaticResource Onboarding.AccentBrush}"
                            HorizontalAlignment="Left">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ProgressScale" ScaleX="0.25" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>
                            <Point X="0" Y="0.5"/>
                        </Border.RenderTransformOrigin>
                    </Border>
                </Border>

                <!-- Drag area + Skip -->
                <Grid Height="48" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <TextBlock x:Name="SkipButton" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Margin="0,0,24,0" Cursor="Hand"
                               MouseLeftButtonDown="Skip_Click"
                               FontSize="13" FontWeight="Medium"
                               Text="{x:Static resx:Resources.OnboardingSkip}"
                               Foreground="{StaticResource Onboarding.Text.Tertiary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Onboarding.Text.Tertiary}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Onboarding.Text.Secondary}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>

            <!-- ═══ CONTENT ═══ -->
            <Grid Grid.Row="1" Margin="56,24,56,0">

                <!-- ══ PAGE 0: WELCOME ══ -->
                <Grid x:Name="Page0" Visibility="{Binding IsPage0, Converter={StaticResource BoolVis}}">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="Page0Translate"/>
                    </Grid.RenderTransform>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400">
                        <!-- Logo -->
                        <Border Width="72" Height="72" CornerRadius="16"
                                Background="#10FFFFFF"
                                HorizontalAlignment="Center" Margin="0,0,0,32">
                            <Image Width="52" Height="52"
                                   Source="/BetterTrumpet;component/Assets/icon.png"
                                   RenderOptions.BitmapScalingMode="Fant"/>
                        </Border>

                        <TextBlock Text="Welcome to" FontSize="15"
                                   Foreground="{StaticResource Onboarding.Text.Secondary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="BetterTrumpet" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource Onboarding.Text.Primary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

                        <TextBlock Text="{Binding SubtitleText}" FontSize="14"
                                   Foreground="{StaticResource Onboarding.Text.Secondary}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   LineHeight="22" Margin="0,0,0,24"/>

                        <!-- Version badge -->
                        <Border Background="#0A3B9EFF" CornerRadius="6" Padding="12,6"
                                HorizontalAlignment="Center">
                            <TextBlock x:Name="VersionText" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource Onboarding.AccentBrush}"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ══ PAGE 1: SETUP (Audio + Appearance) ══ -->
                <ScrollViewer x:Name="Page1" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsPage1, Converter={StaticResource BoolVis}}">
                    <ScrollViewer.RenderTransform>
                        <TranslateTransform x:Name="Page1Translate"/>
                    </ScrollViewer.RenderTransform>
                    <StackPanel Margin="0,0,8,0">
                        <!-- Audio Device Section -->
                        <TextBlock Text="🔊 Audio Output" Style="{StaticResource Onboarding.SectionTitle}"/>
                        <TextBlock Text="Choose your preferred playback device"
                                   Style="{StaticResource Onboarding.SectionSubtitle}"/>

                        <!-- No devices warning -->
                        <Border Padding="16,12" CornerRadius="6" Margin="0,0,0,16"
                                Background="#15FFD54F"
                                Visibility="{Binding HasNoDevices, Converter={StaticResource BoolVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="#FFD54F" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{x:Static resx:Resources.OnboardingNoDevices}" FontSize="13"
                                           Foreground="{StaticResource Onboarding.Text.Secondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Device list -->
                        <ItemsControl ItemsSource="{Binding AudioDevices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource Onboarding.RadioButton}"
                                                 GroupName="AudioDevice"
                                                 IsChecked="{Binding IsDefault, Mode=TwoWay}"
                                                 Content="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Appearance Section -->
                        <TextBlock Text="🎨 Appearance" Style="{StaticResource Onboarding.SectionTitle}" Margin="0,32,0,8"/>
                        <TextBlock Text="Choose your theme preference"
                                   Style="{StaticResource Onboarding.SectionSubtitle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- System Theme -->
                            <Border x:Name="Theme0Card" Grid.Column="0"
                                    Style="{StaticResource Onboarding.SelectableCard}"
                                    MouseLeftButtonDown="Theme0_Click"
                                    Tag="{Binding SelectedThemeIndex, Converter={StaticResource ThemeIndexToTagConverter}}">
                                <StackPanel>
                                    <Border Height="80" Background="#0A000000" CornerRadius="6,6,0,0"
                                            Margin="-16,-14,-16,0" Padding="12">
                                        <Grid>
                                            <Ellipse Width="32" Height="32" Fill="#25FFFFFF"
                                                     HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            <Rectangle Width="60" Height="6" RadiusX="3" RadiusY="3"
                                                       Fill="#20FFFFFF" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" Margin="0,0,0,12"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock Text="{x:Static resx:Resources.OnboardingSystemTheme}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Onboarding.Text.Primary}"/>
                                        <TextBlock Text="{x:Static resx:Resources.OnboardingSystemThemeDesc}"
                                                   FontSize="12" Margin="0,4,0,0"
                                                   Foreground="{StaticResource Onboarding.Text.Tertiary}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Custom Theme -->
                            <Border x:Name="Theme1Card" Grid.Column="2"
                                    Style="{StaticResource Onboarding.SelectableCard}"
                                    MouseLeftButtonDown="Theme1_Click">
                                <StackPanel>
                                    <Border Height="80" CornerRadius="6,6,0,0"
                                            Margin="-16,-14,-16,0" Padding="12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#202196F3" Offset="0"/>
                                                <GradientStop Color="#207C4DFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <Ellipse Width="32" Height="32" Fill="#403B9EFF"
                                                     HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            <Rectangle Width="60" Height="6" RadiusX="3" RadiusY="3"
                                                       Fill="#507C4DFF" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" Margin="0,0,0,12"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Margin="0,16,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static resx:Resources.OnboardingCustomTheme}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Onboarding.Text.Primary}"/>
                                            <Border Background="#10FFD54F" CornerRadius="4" Padding="5,2" Margin="6,0,0,0">
                                                <TextBlock Text="NEW" FontSize="9" FontWeight="Bold" Foreground="#FFD54F"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{x:Static resx:Resources.OnboardingCustomThemeDesc}"
                                                   FontSize="12" Margin="0,4,0,0"
                                                   Foreground="{StaticResource Onboarding.Text.Tertiary}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ PAGE 2: PRIVACY ══ -->
                <ScrollViewer x:Name="Page2" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsPage2, Converter={StaticResource BoolVis}}">
                    <ScrollViewer.RenderTransform>
                        <TranslateTransform x:Name="Page2Translate"/>
                    </ScrollViewer.RenderTransform>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="🔒 Privacy" Style="{StaticResource Onboarding.SectionTitle}"/>
                        <TextBlock Text="{Binding SubtitleText}"
                                   Style="{StaticResource Onboarding.SectionSubtitle}"/>

                        <!-- Trust badges -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Background="#102196F3" CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8D8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="No Ads" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Onboarding.Text.Primary}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#102196F3" CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8D8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="No Tracking" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Onboarding.Text.Primary}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#102196F3" CornerRadius="6" Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8D8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="No Selling" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Onboarding.Text.Primary}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Telemetry -->
                        <Border Style="{StaticResource Onboarding.Card}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingCrashReports}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource Onboarding.Text.Primary}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingCrashReportsDesc}"
                                               FontSize="13"
                                               Foreground="{StaticResource Onboarding.Text.Tertiary}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource Onboarding.Toggle}"
                                          IsChecked="{Binding IsTelemetryEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Run at Startup -->
                        <Border Style="{StaticResource Onboarding.Card}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingLaunchAtStartup}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource Onboarding.Text.Primary}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Static resx:Resources.OnboardingLaunchAtStartupDesc}"
                                               FontSize="13"
                                               Foreground="{StaticResource Onboarding.Text.Tertiary}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource Onboarding.Toggle}"
                                          IsChecked="{Binding RunAtStartup, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Update Channel -->
                        <Border Style="{StaticResource Onboarding.Card}">
                            <StackPanel>
                                <TextBlock Text="{x:Static resx:Resources.OnboardingAutoUpdates}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource Onboarding.Text.Primary}" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- All -->
                                    <Border Grid.Column="0" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                            Margin="0,0,4,0" MouseLeftButtonDown="UpdateChannel0_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#08FFFFFF"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UpdateChannelIndex}" Value="0">
                                                        <Setter Property="BorderBrush" Value="{StaticResource Onboarding.AccentBrush}"/>
                                                        <Setter Property="Background" Value="#1A3B9EFF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{x:Static resx:Resources.OnboardingUpdateAll}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource Onboarding.Text.Primary}"/>
                                            <TextBlock Text="{x:Static resx:Resources.OnboardingUpdateRecommended}"
                                                       FontSize="10" Opacity="0.6"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource Onboarding.AccentBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Minor+Major -->
                                    <Border Grid.Column="1" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                            Margin="0,0,4,0" MouseLeftButtonDown="UpdateChannel1_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#08FFFFFF"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UpdateChannelIndex}" Value="1">
                                                        <Setter Property="BorderBrush" Value="{StaticResource Onboarding.AccentBrush}"/>
                                                        <Setter Property="Background" Value="#1A3B9EFF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{x:Static resx:Resources.OnboardingUpdateMinor}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource Onboarding.Text.Primary}"/>
                                    </Border>

                                    <!-- None -->
                                    <Border Grid.Column="2" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="UpdateChannel3_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#08FFFFFF"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UpdateChannelIndex}" Value="3">
                                                        <Setter Property="BorderBrush" Value="{StaticResource Onboarding.AccentBrush}"/>
                                                        <Setter Property="Background" Value="#1A3B9EFF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{x:Static resx:Resources.OnboardingUpdateNone}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource Onboarding.Text.Primary}"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ PAGE 3: READY ══ -->
                <Grid x:Name="Page3" Visibility="{Binding IsPage3, Converter={StaticResource BoolVis}}">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="Page3Translate"/>
                    </Grid.RenderTransform>
                    <StackPanel VerticalAlignment="Center" MaxWidth="420">
                        <!-- Check circle -->
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="#153B9EFF"
                                HorizontalAlignment="Left" Margin="0,0,0,32">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource Onboarding.AccentBrush}"/>
                        </Border>

                        <TextBlock Text="{x:Static resx:Resources.OnboardingAllReady}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource Onboarding.Text.Primary}" Margin="0,0,0,8"/>
                        <TextBlock Text="{x:Static resx:Resources.OnboardingAllReadyDesc}"
                                   FontSize="14" TextWrapping="Wrap" LineHeight="22"
                                   Foreground="{StaticResource Onboarding.Text.Secondary}" Margin="0,0,0,32"/>

                        <!-- Check items -->
                        <StackPanel x:Name="CheckItem0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource Onboarding.AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{x:Static resx:Resources.OnboardingDeviceConfigured}" FontSize="14"
                                       Foreground="{StaticResource Onboarding.Text.Secondary}"/>
                        </StackPanel>
                        <StackPanel x:Name="CheckItem1" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource Onboarding.AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{x:Static resx:Resources.OnboardingAppearanceChosen}" FontSize="14"
                                       Foreground="{StaticResource Onboarding.Text.Secondary}"/>
                        </StackPanel>
                        <StackPanel x:Name="CheckItem2" Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource Onboarding.AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{x:Static resx:Resources.OnboardingPrivacyConfigured}" FontSize="14"
                                       Foreground="{StaticResource Onboarding.Text.Secondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ═══ BOTTOM BAR ═══ -->
            <Grid Grid.Row="2" Margin="56,0,56,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back -->
                <Border Grid.Column="0" Style="{StaticResource Onboarding.SecondaryButton}"
                        MouseLeftButtonDown="Back_Click"
                        Visibility="{Binding CanGoBack, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{x:Static resx:Resources.OnboardingBack}" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource Onboarding.Text.Tertiary}"/>
                </Border>

                <!-- Step indicator dots -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot0" Width="7" Height="7" Margin="4,0" Fill="{StaticResource Onboarding.AccentBrush}"/>
                    <Ellipse x:Name="Dot1" Width="7" Height="7" Margin="4,0" Fill="#25FFFFFF"/>
                    <Ellipse x:Name="Dot2" Width="7" Height="7" Margin="4,0" Fill="#25FFFFFF"/>
                    <Ellipse x:Name="Dot3" Width="7" Height="7" Margin="4,0" Fill="#25FFFFFF"/>
                </StackPanel>

                <!-- Continue/Done button -->
                <Border x:Name="CtaButton" Grid.Column="2"
                        Style="{StaticResource Onboarding.PrimaryButton}"
                        MouseLeftButtonDown="Next_Click">
                    <TextBlock Text="{Binding NextButtonText}" FontSize="13" FontWeight="SemiBold"
                               Foreground="#FF0E0E12"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
