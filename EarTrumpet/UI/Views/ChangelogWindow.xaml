<Window x:Class="EarTrumpet.UI.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resx="clr-namespace:EarTrumpet.Properties"
        Title="What's New in BetterTrumpet"
        Width="620" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/EarTrumpet;component/UI/Controls/OnboardingComponents.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True"
            Background="{StaticResource Onboarding.SurfaceBrush}"
            BorderBrush="#08FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- ═══ HEADER ═══ -->
            <Grid Grid.Row="0" Margin="0,0,0,0" MouseLeftButtonDown="TitleBar_Drag">
                <!-- Close button -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,16,0"
                        Width="32" Height="32" CornerRadius="6" Cursor="Hand"
                        MouseLeftButtonDown="Close_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#10FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{StaticResource Onboarding.Text.Tertiary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Margin="56,40,56,0">
                    <!-- Version badge -->
                    <Border HorizontalAlignment="Left" CornerRadius="6" Padding="12,6" Margin="0,0,0,16"
                            Background="#0A3B9EFF">
                        <TextBlock x:Name="VersionBadge" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource Onboarding.AccentBrush}"/>
                    </Border>

                    <TextBlock x:Name="MainTitle" Text="{x:Static resx:Resources.ChangelogTitle}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource Onboarding.Text.Primary}" Margin="0,0,0,6"/>
                    <TextBlock Text="{x:Static resx:Resources.ChangelogSubtitle}"
                               FontSize="14"
                               Foreground="{StaticResource Onboarding.Text.Secondary}" Margin="0,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ═══ CONTENT ═══ -->
            <ScrollViewer Grid.Row="1" Margin="56,28,48,0"
                          Padding="0,0,8,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ContentPanel"/>
            </ScrollViewer>

            <!-- ═══ BOTTOM BAR ═══ -->
            <Grid Grid.Row="2" Margin="56,0,56,0">
                <Border VerticalAlignment="Top" Height="1" Background="#08FFFFFF"/>
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource Onboarding.Text.Muted}"
                               Text="{x:Static resx:Resources.ChangelogThanks}"/>

                    <Border Grid.Column="1" Style="{StaticResource Onboarding.PrimaryButton}"
                            MouseLeftButtonDown="Continue_Click">
                        <TextBlock Text="{x:Static resx:Resources.ChangelogContinue}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#FF0E0E12"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
