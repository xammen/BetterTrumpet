<Window x:Class="EarTrumpet.UI.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resx="clr-namespace:EarTrumpet.Properties"
        Title="What's New in BetterTrumpet"
        Width="540" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <!-- Palette now comes from SharedTokens.xaml (via App.xaml MergedDictionaries) -->
        <!-- Local aliases for backward compatibility with code-behind references -->
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource BT.Accent}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource BT.Surface}"/>
        <SolidColorBrush x:Key="T1" Color="{StaticResource BT.T1}"/>
        <SolidColorBrush x:Key="T2" Color="{StaticResource BT.T2}"/>
        <SolidColorBrush x:Key="T3" Color="{StaticResource BT.T3}"/>
    </Window.Resources>

    <Border CornerRadius="14" ClipToBounds="True" Background="{StaticResource BT.BgBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.35" Color="Black"/>
        </Border.Effect>
        <Grid>
            <!-- Gradient mesh (same as onboarding) -->
            <Border CornerRadius="14,14,0,0" VerticalAlignment="Top" Height="200"
                    IsHitTestVisible="False" Opacity="0.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1565C0" Offset="0"/>
                        <GradientStop Color="#1A2196F3" Offset="0.3"/>
                        <GradientStop Color="#1000BCD4" Offset="0.6"/>
                        <GradientStop Color="#087C4DFF" Offset="0.85"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Inner stroke -->
            <Border CornerRadius="14" BorderThickness="1" BorderBrush="#08FFFFFF" IsHitTestVisible="False"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="72"/>
                </Grid.RowDefinitions>

                <!-- ═══ HEADER ═══ -->
                <Grid Grid.Row="0" Margin="0,0,0,0" MouseLeftButtonDown="TitleBar_Drag">
                    <!-- Close button -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,14,0"
                            Width="28" Height="28" CornerRadius="6" Cursor="Hand"
                            MouseLeftButtonDown="Close_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#15FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource T3}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Margin="48,36,48,0">
                        <!-- Version badge -->
                        <Border HorizontalAlignment="Left" CornerRadius="12" Padding="12,5"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.12"/>
                            </Border.Background>
                            <TextBlock x:Name="VersionBadge" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Border>

                        <TextBlock x:Name="MainTitle" Text="{x:Static resx:Resources.ChangelogTitle}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource T1}" Margin="0,0,0,6"/>
                        <TextBlock Text="{x:Static resx:Resources.ChangelogSubtitle}"
                                   FontSize="13" Foreground="{StaticResource T2}" Margin="0,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- ═══ CONTENT ═══ -->
                <ScrollViewer Grid.Row="1" Margin="48,24,40,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ContentPanel" Margin="0,0,8,16"/>
                </ScrollViewer>

                <!-- ═══ BOTTOM BAR ═══ -->
                <Grid Grid.Row="2" Margin="48,0,48,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               FontSize="11" Foreground="{StaticResource T3}"
                               Text="{x:Static resx:Resources.ChangelogThanks}"/>

                    <Border Grid.Column="1" CornerRadius="20" Cursor="Hand"
                            MouseLeftButtonDown="Continue_Click" Padding="28,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value><SolidColorBrush Color="#5BB0FF"/></Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{x:Static resx:Resources.ChangelogContinue}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#FF0E0E12"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
