<Window x:Class="EarTrumpet.UI.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resx="clr-namespace:EarTrumpet.Properties"
        Title="{x:Static resx:Resources.ChangelogTitle}"
        Width="600" Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BetterTrumpet;component/UI/Controls/OnboardingComponents.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="#1A1A1A" CornerRadius="8" BorderBrush="#2E2E2E" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Subtle animated gradient overlay -->
            <Border Grid.RowSpan="3" CornerRadius="8" IsHitTestVisible="False" Opacity="0.15">
                <Border.Background>
                    <RadialGradientBrush x:Name="PulseGradient" GradientOrigin="0.5,0.3" Center="0.5,0.3" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="40,40,40,20">
                <TextBlock x:Name="VersionBadge"
                           FontSize="12"
                           Foreground="#0078D4"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <TextBlock Text="{x:Static resx:Resources.ChangelogTitle}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,8"/>

                <TextBlock Text="{x:Static resx:Resources.ChangelogSubtitle}"
                           FontSize="14"
                           Foreground="#B0B0B0"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Margin="40,0" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Background" Value="#10FFFFFF"/>
                        <Setter Property="Width" Value="8"/>
                    </Style>
                </ScrollViewer.Resources>
                <StackPanel x:Name="ContentPanel"/>
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="2" Margin="40,20,40,40">
                <Button Content="{x:Static resx:Resources.ChangelogContinue}"
                        Style="{StaticResource OnboardingPrimaryButton}"
                        HorizontalAlignment="Right"
                        Click="Continue_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
