                        <Hyperlink Command="{Binding OpenDiagnosticsCommand}">
                            <Run Text="{x:Static resx:Resources.TroubleshootEarTrumpetText}" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Health info (for power users) -->
                <Border Margin="12,20,12,0"
                        Padding="12"
                        CornerRadius="6"
                        Background="#0DFFFFFF">
                    <TextBlock FontSize="11" Opacity="0.4" FontFamily="Consolas"
                               Text="{Binding HealthSummary}" />
                </Border>
            </StackPanel>
