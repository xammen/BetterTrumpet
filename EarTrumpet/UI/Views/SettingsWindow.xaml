<Window x:Class="EarTrumpet.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Event="clr-namespace:EarTrumpet.Extensions.EventBinding"
        xmlns:Theme="clr-namespace:EarTrumpet.UI.Themes"
        xmlns:b="clr-namespace:EarTrumpet.UI.Behaviors"
        xmlns:ctl="clr-namespace:EarTrumpet.UI.Controls"
        xmlns:datamodel="clr-namespace:EarTrumpet.DataModel"
        xmlns:local="clr-namespace:EarTrumpet"
        xmlns:resx="clr-namespace:EarTrumpet.Properties"
        xmlns:vm="clr-namespace:EarTrumpet.UI.ViewModels"
        xmlns:helpers="clr-namespace:EarTrumpet.UI.Helpers"
        Name="WindowRoot"
        Title="{Binding Title}"
        Width="800"
        Height="600"
        MinWidth="770"
        MinHeight="320"
        Theme:AcrylicBrush.Background="AcrylicColor_Settings"
        Theme:Options.Source="App"
        b:FrameworkElementEx.DisplaySettingsChanged="{Binding DisplaySettingsChanged}"
        b:FrameworkElementEx.FlowDirection="Auto"
        Background="Transparent"
        Closing="{Event:Binding OnClosing}"
        ResizeMode="CanResize"
        Style="{StaticResource DialogWindowStyle}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <helpers:IntToBoolConverter x:Key="IntToBoolConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:PercentWidthConverter x:Key="PercentWidthConverter" />
        <local:ThumbMarginConverter x:Key="ThumbMarginConverter" />

        <!-- Named brushes: local aliases kept for backward compat; prefer BT.* tokens directly -->
        <!-- PanelBackgroundBrush → BT.SurfaceBrush -->
        <!-- BorderSubtleBrush   → BT.StrokeMidBrush -->
        <!-- HoverBackgroundBrush → BT.HoverBrush -->
        <!-- HoverBorderBrush    → BT.HoverBorderBrush -->
        <!-- ActiveBorderBrush   → BT.StrokeStrongBrush -->
        <!-- PressedBackgroundBrush → BT.PressedBrush -->
        <!-- SelectedBorderBrush → BT.SelectedBorderBrush -->
        <!-- DeleteBackgroundBrush → BT.DangerDimBrush -->
        <!-- DeleteTextBrush     → BT.DangerBrush -->
        <!-- SuccessAccentBrush  → BT.SuccessBrush -->
        <!-- WarningAmberBrush   → BT.WarningBrush -->
        <!-- WarningAmberDimBrush → BT.WarningDimBrush -->
        <!-- Keep: ListItemBackgroundBrush (#08FFFFFF) — more subtle than BT.Surface -->
        <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="#08FFFFFF"/>
        <!-- Keep: ListItemHoverBrush (#12FFFFFF) — lighter hover for list context -->
        <SolidColorBrush x:Key="ListItemHoverBrush" Color="#12FFFFFF"/>
        <!-- Keep: Brand accent (gold #FFC857) — not in shared tokens -->
        <Color x:Key="BrandAccentColor">#FFFFC857</Color>
        <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccentColor}"/>
        <SolidColorBrush x:Key="BrandAccentDimBrush" Color="#40FFC857"/>

        <!-- Reusable action button style — delegates to BT.ActionButton from SharedTokens -->
        <Style x:Key="ActionButtonBorder" TargetType="Border" BasedOn="{StaticResource BT.ActionButton}"/>

        <!-- Section card style — delegates to BT.SectionCard from SharedTokens -->
        <Style x:Key="SectionCardBorder" TargetType="Border" BasedOn="{StaticResource BT.SectionCard}"/>

        <!-- Section icon style — delegates to BT.SectionIcon from SharedTokens -->
        <Style x:Key="SectionIconBorder" TargetType="Border" BasedOn="{StaticResource BT.SectionIcon}"/>
        <DataTemplate DataType="{x:Type vm:EarTrumpetShortcutsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                    <!-- Hotkey card: Open Flyout -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsOpenEarTrumpetText}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12">
                                    <Run Text="{x:Static resx:Resources.SettingsDefaultPrefix}" /><Run Text="{Binding DefaultHotKey, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <ContentControl Content="{Binding OpenFlyoutHotkey}" IsTabStop="False" Margin="48,0,0,0" />
                    </StackPanel>
                </Border>

                    <!-- Hotkey card: Open Mixer -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsOpenMixerText}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12">
                                    <Run Text="{x:Static resx:Resources.SettingsDefaultPrefix}" /><Run Text="{Binding DefaultMixerHotKey, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <ContentControl Content="{Binding OpenMixerHotkey}" IsTabStop="False" Margin="48,0,0,0" />
                    </StackPanel>
                </Border>

                    <!-- Hotkey card: Open Settings -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsOpenSettingsText}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12">
                                    <Run Text="{x:Static resx:Resources.SettingsDefaultPrefix}" /><Run Text="{Binding DefaultSettingsHotKey, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <ContentControl Content="{Binding OpenSettingsHotkey}" IsTabStop="False" Margin="48,0,0,0" />
                    </StackPanel>
                </Border>

                    <!-- Hotkey card: Volume Up/Down -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsAbsoluteVolume}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsAbsoluteVolumeDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{x:Static resx:Resources.SettingsAbsoluteVolumeUpText}" FontSize="13" Margin="0,0,0,6" />
                        <ContentControl Content="{Binding AbsoluteVolumeUpHotkey}" IsTabStop="False" Margin="0,0,0,14" />

                        <Border Height="1" Background="{StaticResource BT.StrokeBrush}" Margin="0,0,0,14" />

                        <TextBlock Text="{x:Static resx:Resources.SettingsAbsoluteVolumeDownText}" FontSize="13" Margin="0,0,0,6" />
                        <ContentControl Content="{Binding AbsoluteVolumeDownHotkey}" IsTabStop="False" />
                    </StackPanel>
                </Border>

                    <!-- Hotkey card: Switch Default Device -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsSwitchDevice}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12">
                                    <Run Text="{x:Static resx:Resources.SettingsDefaultPrefix}" /><Run Text="{Binding DefaultSwitchDeviceHotKey, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <ContentControl Content="{Binding SwitchDeviceHotkey}" IsTabStop="False" Margin="48,0,0,0" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EarTrumpetMouseSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE962;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsScrollWheel}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsScrollWheelDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <CheckBox HorizontalAlignment="Left" Margin="0,0,0,10"
                                  Content="{x:Static resx:Resources.SettingsUseScrollWheelInTray}"
                                  IsChecked="{Binding UseScrollWheelInTray, Mode=TwoWay}"
                                  ToolTip="{x:Static resx:Resources.SettingsScrollWheelTrayTip}" />
                        <CheckBox HorizontalAlignment="Left"
                                  Content="{x:Static resx:Resources.SettingsUseGlobalMouseWheelHook}"
                                  IsChecked="{Binding UseGlobalMouseWheelHook, Mode=TwoWay}"
                                  ToolTip="{x:Static resx:Resources.SettingsScrollWheelGlobalTip}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EarTrumpetCommunitySettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsVolumeScale}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsVolumeScaleDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <CheckBox HorizontalAlignment="Left"
                                  Content="{x:Static resx:Resources.SettingsUseLogarithmicVolume}"
                                  IsChecked="{Binding UseLogarithmicVolume, Mode=TwoWay}"
                                  ToolTip="{x:Static resx:Resources.SettingsLogVolumeDesc}" />
                        <TextBlock Style="{StaticResource BodySubText}" FontSize="12" Opacity="0.7" Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Text="{x:Static resx:Resources.SettingsLogVolumeDesc}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>
        <!-- Performance Settings Page -->
        <DataTemplate DataType="{x:Type vm:EarTrumpetAnimationSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                    <!-- SECTION: Battery Optimization -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="{StaticResource BT.SurfaceBrush}">
                                    <TextBlock Text="&#xEA94;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resx:Resources.SettingsEcoMode}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsEcoModeDesc}"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox Content="{x:Static resx:Resources.SettingsEcoModeEnable}"
                                      IsChecked="{Binding EcoMode, Mode=TwoWay}" Margin="0,8,0,6"
                                      ToolTip="{x:Static resx:Resources.SettingsEcoModeEnableTip}" />
                            <CheckBox Content="{x:Static resx:Resources.SettingsAutoEcoMode}"
                                      IsChecked="{Binding AutoEcoMode, Mode=TwoWay}" Margin="0,0,0,14"
                                      ToolTip="{x:Static resx:Resources.SettingsAutoEcoModeTip}" />

                            <Border Padding="10,8" CornerRadius="6" Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12">
                                    <Run Text="{x:Static resx:Resources.SettingsCurrentRefreshRate}" />
                                    <Run Text="{Binding EffectiveFpsText, Mode=OneWay}" FontWeight="SemiBold"
                                         Foreground="{StaticResource BrandAccentBrush}" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Animations -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="{StaticResource BT.SurfaceBrush}">
                                    <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resx:Resources.SettingsAnimations}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsAnimationsDesc}"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox Content="{x:Static resx:Resources.SettingsSmoothVolumeAnimation}"
                                      IsChecked="{Binding UseSmoothVolumeAnimation, Mode=TwoWay}" Margin="0,8,0,12"
                                      ToolTip="{x:Static resx:Resources.SettingsSmoothVolumeAnimationTip}" />

                            <StackPanel Orientation="Vertical" Margin="0,0,0,0"
                                        IsEnabled="{Binding UseSmoothVolumeAnimation}">
                                <TextBlock Text="{x:Static resx:Resources.SettingsAnimationSpeedLabel}" Margin="0,0,0,8" FontSize="13" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static resx:Resources.SettingsSpeedSlow}" Style="{StaticResource BodySubText}"
                                               VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <Slider Grid.Column="1" Minimum="1" Maximum="10"
                                            Value="{Binding VolumeAnimationSpeed, Mode=TwoWay}"
                                            TickFrequency="1" IsSnapToTickEnabled="True" />
                                    <TextBlock Grid.Column="2" Text="{x:Static resx:Resources.SettingsSpeedFast}" Style="{StaticResource BodySubText}"
                                               VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Peak Meter -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="{StaticResource BT.SurfaceBrush}">
                                    <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resx:Resources.SettingsPeakMeter}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsPeakMeterDesc}"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Eco Mode override warning — amber accent -->
                            <Border Padding="12,8" CornerRadius="6" Margin="0,0,0,16"
                                    Background="{StaticResource BT.WarningDimBrush}"
                                    BorderBrush="#40FFA726" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="{StaticResource BT.WarningBrush}" />
                                    <TextBlock FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BT.WarningBrush}">
                                        <Run Text="{x:Static resx:Resources.SettingsEcoModeOverridden}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Segmented Control for FPS -->
                            <TextBlock Text="{x:Static resx:Resources.SettingsRefreshRate}" FontSize="13" Margin="0,0,0,10" />
                            <Border CornerRadius="8" Background="{StaticResource ListItemBackgroundBrush}" Padding="3"
                                    BorderBrush="{StaticResource BT.SurfaceBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 5 FPS -->
                                    <Border Grid.Column="0" Padding="0,8" MouseLeftButtonDown="Fps5Card_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding PeakMeterFps}" Value="5">
                                                <Setter Property="Background" Value="#20FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="5 FPS" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{x:Static resx:Resources.SettingsFpsUltraSaver}" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 20 FPS -->
                                    <Border Grid.Column="1" Padding="0,8" MouseLeftButtonDown="Fps20Card_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding PeakMeterFps}" Value="20">
                                                <Setter Property="Background" Value="#20FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="20 FPS" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{x:Static resx:Resources.SettingsFpsBatterySaver}" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- 30 FPS -->
                                    <Border Grid.Column="2" Padding="0,8" MouseLeftButtonDown="Fps30Card_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding PeakMeterFps}" Value="30">
                                                <Setter Property="Background" Value="#20FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="30 FPS" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{x:Static resx:Resources.SettingsFpsBalanced}" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- 60 FPS -->
                                    <Border Grid.Column="3" Padding="0,8" MouseLeftButtonDown="Fps60Card_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding PeakMeterFps}" Value="60">
                                                <Setter Property="Background" Value="#20FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="60 FPS" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{x:Static resx:Resources.SettingsFpsSmoothest}" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

            </StackPanel>
        </DataTemplate>

        <!-- Appearance Settings Page — Visual First Redesign -->
        <DataTemplate DataType="{x:Type vm:EarTrumpetColorsSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- PEAK METER VISUAL STYLE (Experimental)              -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <Border Margin="0,0,0,16" Padding="16,14" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="{StaticResource BT.SurfaceBrush}">
                                    <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{x:Static resx:Resources.SettingsPeakMeterStyle}" FontSize="15" FontWeight="SemiBold" />
                                        <Border CornerRadius="4" Background="#30FFA500" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Experimental" FontSize="10" FontWeight="SemiBold" Foreground="#FFA500" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{x:Static resx:Resources.SettingsPeakMeterStyleDesc}"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                            <Border CornerRadius="8" Background="{StaticResource ListItemBackgroundBrush}" Padding="3"
                                    BorderBrush="{StaticResource BT.SurfaceBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Classic: two thick bars -->
                                    <Border Grid.Column="0" Padding="4,10" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="PeakStyleClassic_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PeakMeterStyleIndex}" Value="0">
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#12FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <StackPanel Height="14" VerticalAlignment="Center" Margin="0,0,0,0">
                                                <Border Width="48" Height="4" CornerRadius="2" Background="White" Opacity="0.6" Margin="0,0,0,2" HorizontalAlignment="Left" />
                                                <Border Width="36" Height="4" CornerRadius="2" Background="White" Opacity="0.6" HorizontalAlignment="Left" />
                                            </StackPanel>
                                            <TextBlock Text="Classic" FontSize="10" HorizontalAlignment="Center" Margin="0,6,0,0" Opacity="0.7" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Dotted: thin dashed line -->
                                    <Border Grid.Column="1" Padding="4,10" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="PeakStyleDotted_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PeakMeterStyleIndex}" Value="1">
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#12FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Grid Height="14" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="3" Height="2" Background="White" Opacity="0.5" Margin="0,0,2,0" />
                                                    <Border Width="3" Height="2" Background="White" Opacity="0.5" Margin="0,0,2,0" />
                                                    <Border Width="3" Height="2" Background="White" Opacity="0.5" Margin="0,0,2,0" />
                                                    <Border Width="3" Height="2" Background="White" Opacity="0.5" Margin="0,0,2,0" />
                                                    <Border Width="3" Height="2" Background="White" Opacity="0.5" Margin="0,0,2,0" />
                                                    <Border Width="3" Height="2" Background="White" Opacity="0.5" Margin="0,0,2,0" />
                                                    <Border Width="3" Height="2" Background="White" Opacity="0.3" Margin="0,0,2,0" />
                                                    <Border Width="3" Height="2" Background="White" Opacity="0.15" />
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Dotted" FontSize="10" HorizontalAlignment="Center" Margin="0,6,0,0" Opacity="0.7" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Blocks: chunky segments -->
                                    <Border Grid.Column="2" Padding="4,10" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="PeakStyleBlocks_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PeakMeterStyleIndex}" Value="2">
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#12FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Grid Height="14" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="6" Height="3" Background="White" Opacity="0.55" Margin="0,0,2,0" />
                                                    <Border Width="6" Height="3" Background="White" Opacity="0.55" Margin="0,0,2,0" />
                                                    <Border Width="6" Height="3" Background="White" Opacity="0.55" Margin="0,0,2,0" />
                                                    <Border Width="6" Height="3" Background="White" Opacity="0.55" Margin="0,0,2,0" />
                                                    <Border Width="6" Height="3" Background="White" Opacity="0.3" Margin="0,0,2,0" />
                                                    <Border Width="6" Height="3" Background="White" Opacity="0.15" />
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Blocks" FontSize="10" HorizontalAlignment="Center" Margin="0,6,0,0" Opacity="0.7" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Bars: thin clean line -->
                                    <Border Grid.Column="3" Padding="4,10" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="PeakStyleBars_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PeakMeterStyleIndex}" Value="3">
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#12FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Grid Height="14" VerticalAlignment="Center">
                                                <Border Width="48" Height="1.5" CornerRadius="1" Background="White" Opacity="0.4" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                            </Grid>
                                            <TextBlock Text="Line" FontSize="10" HorizontalAlignment="Center" Margin="0,6,0,0" Opacity="0.7" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Wave: spaced dashes -->
                                    <Border Grid.Column="4" Padding="4,10" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="PeakStyleWave_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PeakMeterStyleIndex}" Value="4">
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#12FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Grid Height="14" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="5" Height="2" CornerRadius="1" Background="White" Opacity="0.45" Margin="0,0,4,0" />
                                                    <Border Width="5" Height="2" CornerRadius="1" Background="White" Opacity="0.45" Margin="0,0,4,0" />
                                                    <Border Width="5" Height="2" CornerRadius="1" Background="White" Opacity="0.45" Margin="0,0,4,0" />
                                                    <Border Width="5" Height="2" CornerRadius="1" Background="White" Opacity="0.3" Margin="0,0,4,0" />
                                                    <Border Width="5" Height="2" CornerRadius="1" Background="White" Opacity="0.15" />
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Dashes" FontSize="10" HorizontalAlignment="Center" Margin="0,6,0,0" Opacity="0.7" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- MASTER TOGGLE: Enable Custom Colors                -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <Border Margin="0,0,0,16" Padding="16,12" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsCustomColors}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsCustomColorsDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                            <CheckBox Grid.Column="2" VerticalAlignment="Center"
                                      IsChecked="{Binding UseCustomSliderColors, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- SEGMENTED TAB BAR: [Dynamic] [Presets] [Custom]     -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <Border Margin="0,0,0,16" CornerRadius="8" Padding="3"
                            Background="{StaticResource ListItemBackgroundBrush}" BorderBrush="{StaticResource BT.StrokeMidBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Tab 0: Dynamic -->
                            <Border Grid.Column="0" Padding="0,9" CornerRadius="6" Cursor="Hand"
                                    MouseLeftButtonDown="AppearanceTab0_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                                <Setter Property="Background" Value="#20FFFFFF" />
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#12FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsTabDynamic}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Tab 1: Presets -->
                            <Border Grid.Column="1" Padding="0,9" CornerRadius="6" Cursor="Hand"
                                    MouseLeftButtonDown="AppearanceTab1_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                                <Setter Property="Background" Value="#20FFFFFF" />
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#12FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsTabPresets}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Tab 2: Custom -->
                            <Border Grid.Column="2" Padding="0,9" CornerRadius="6" Cursor="Hand"
                                    MouseLeftButtonDown="AppearanceTab2_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab}" Value="2">
                                                <Setter Property="Background" Value="#20FFFFFF" />
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#12FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock Text="&#xE2B1;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsTabCustom}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- HERO PREVIEW: Always visible large slider preview  -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static resx:Resources.SettingsLivePreview}" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                <!-- Randomize button -->
                                     <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8" Cursor="Hand"
                                         ToolTip="{x:Static resx:Resources.SettingsRandomizeTooltip}" MouseLeftButtonDown="RandomizeColors_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource BT.SurfaceBrush}" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BT.HoverBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandAccentBrush}" />
                                </Border>
                            </Grid>
                            <!-- Realistic flyout preview — enlarged -->
                            <Border CornerRadius="10" Padding="0" BorderThickness="1" BorderBrush="{StaticResource BT.StrokeMidBrush}" ClipToBounds="True">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding WindowBackgroundColor}" />
                                </Border.Background>
                                <StackPanel>
                                    <!-- Row 1: System volume at ~80% -->
                                    <Grid Height="44" Margin="16,10,16,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding SliderTrackFillColor}" Opacity="0.5" />
                                            </Border.Background>
                                            <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding TextColorValue}" />
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                            <Border Height="4" CornerRadius="2">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackBackgroundColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Height="4" CornerRadius="2" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource PercentWidthConverter}" ConverterParameter="0.80" FallbackValue="200" />
                                                </Border.Width>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackFillColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Height="3" CornerRadius="1.5" HorizontalAlignment="Left" Margin="0,-6,0,0" Opacity="0.5">
                                                <Border.Width>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource PercentWidthConverter}" ConverterParameter="0.62" FallbackValue="155" />
                                                </Border.Width>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding PeakMeterColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Width="16" Height="16" CornerRadius="8" HorizontalAlignment="Left">
                                                <Border.Margin>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource ThumbMarginConverter}" ConverterParameter="0.80" />
                                                </Border.Margin>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderThumbColor}" />
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Column="2" Text="80" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding TextColorValue}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Row 2: App at ~50% -->
                                    <Grid Height="44" Margin="16,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding SliderThumbColor}" Opacity="0.45" />
                                            </Border.Background>
                                            <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding TextColorValue}" />
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                            <Border Height="4" CornerRadius="2">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackBackgroundColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Height="4" CornerRadius="2" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource PercentWidthConverter}" ConverterParameter="0.50" FallbackValue="125" />
                                                </Border.Width>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackFillColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Width="16" Height="16" CornerRadius="8" HorizontalAlignment="Left">
                                                <Border.Margin>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource ThumbMarginConverter}" ConverterParameter="0.50" />
                                                </Border.Margin>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderThumbColor}" />
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Column="2" Text="50" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding TextColorValue}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Row 3: Muted app at 100% -->
                                    <Grid Height="44" Margin="16,0,16,10" Opacity="0.45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding PeakMeterColor}" Opacity="0.35" />
                                            </Border.Background>
                                            <TextBlock Text="&#xE74F;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding TextColorValue}" />
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                            <Border Height="4" CornerRadius="2">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackBackgroundColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Height="4" CornerRadius="2" HorizontalAlignment="Stretch">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackFillColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Width="16" Height="16" CornerRadius="8" HorizontalAlignment="Right">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderThumbColor}" />
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Column="2" Text="100" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding TextColorValue}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- TAB 0: DYNAMIC — Album Art Theme                   -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <Border x:Name="TabPanelDynamic"
                            Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="{StaticResource BT.SurfaceBrush}">
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resx:Resources.SettingsDynamicAlbumArt}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsDynamicAlbumArtDesc}"
                                               Style="{StaticResource BodySubText}" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox Content="{x:Static resx:Resources.SettingsEnableDynamicAlbumArt}"
                                      IsChecked="{Binding UseDynamicAlbumArtTheme, Mode=TwoWay}" Margin="0,4,0,0" />

                            <Border Padding="12,10" CornerRadius="8" Margin="0,14,0,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12" TextWrapping="Wrap"
                                           Opacity="0.7">
                                    <Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                    <Run Text="{x:Static resx:Resources.SettingsDynamicAlbumArtInfo}" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- TAB 1: PRESETS — Visual Theme Grid (2 columns)     -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <Border x:Name="TabPanelPresets"
                            Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <!-- Category filter tabs -->
                            <Border CornerRadius="6" Padding="2" Margin="0,0,0,16"
                                    Background="#06FFFFFF">
                                <ItemsControl>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <!-- All -->
                                    <Border Margin="2" MouseLeftButtonDown="CategoryAll_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding SelectedCategory}" Value="All">
                                                <Setter Property="Background" Value="#18FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <TextBlock Text="{x:Static resx:Resources.PresetCategoryAll}" FontSize="12" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Minimal -->
                                    <Border Margin="2" MouseLeftButtonDown="CategoryMinimal_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding SelectedCategory}" Value="Minimal">
                                                <Setter Property="Background" Value="#18FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <TextBlock Text="{x:Static resx:Resources.PresetCategoryMinimal}" FontSize="12" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Brands -->
                                    <Border Margin="2" MouseLeftButtonDown="CategoryBrands_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding SelectedCategory}" Value="Brand">
                                                <Setter Property="Background" Value="#18FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <TextBlock Text="{x:Static resx:Resources.PresetCategoryBrands}" FontSize="12" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Retro -->
                                    <Border Margin="2" MouseLeftButtonDown="CategoryRetro_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding SelectedCategory}" Value="Retro / Gaming">
                                                <Setter Property="Background" Value="#18FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <TextBlock Text="{x:Static resx:Resources.PresetCategoryRetro}" FontSize="12" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Developer -->
                                    <Border Margin="2" MouseLeftButtonDown="CategoryDev_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding SelectedCategory}" Value="Developer">
                                                <Setter Property="Background" Value="#18FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <TextBlock Text="{x:Static resx:Resources.PresetCategoryDeveloper}" FontSize="12" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Nature -->
                                    <Border Margin="2" MouseLeftButtonDown="CategoryNature_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding SelectedCategory}" Value="Nature / Premium">
                                                <Setter Property="Background" Value="#18FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <TextBlock Text="{x:Static resx:Resources.PresetCategoryNature}" FontSize="12" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Accessibility -->
                                    <Border Margin="2" MouseLeftButtonDown="CategoryAccessibility_Click">
                                        <Border.Style><Style TargetType="Border" BasedOn="{StaticResource BT.SegmentItem}">
                                            <Style.Triggers><DataTrigger Binding="{Binding SelectedCategory}" Value="Accessibility">
                                                <Setter Property="Background" Value="#18FFFFFF"/></DataTrigger></Style.Triggers>
                                        </Style></Border.Style>
                                        <TextBlock Text="{x:Static resx:Resources.PresetCategoryAccessibility}" FontSize="12" VerticalAlignment="Center"/>
                                    </Border>
                                </ItemsControl>
                            </Border>

                            <!-- Theme cards grid (2 columns via UniformGrid) -->
                            <ItemsControl ItemsSource="{Binding FilteredThemes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="3" Padding="12" CornerRadius="8" Cursor="Hand"
                                                MouseLeftButtonDown="ThemeCard_Click" Tag="{Binding}"
                                                Background="#10FFFFFF" BorderThickness="1.5" BorderBrush="#18FFFFFF">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#1AFFFFFF" />
                                                            <Setter Property="BorderBrush" Value="#35FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <!-- Mini slider visualization -->
                                                <Border Height="28" CornerRadius="6" Padding="8,0" Margin="0,0,0,8"
                                                        ClipToBounds="True">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding TrackBackgroundColor}" Opacity="0.8" />
                                                    </Border.Background>
                                                    <Grid VerticalAlignment="Center">
                                                        <!-- Track bg -->
                                                        <Border Height="3" CornerRadius="1.5">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="{Binding TrackBackgroundColor}" />
                                                            </Border.Background>
                                                        </Border>
                                                        <!-- Track fill at ~65% -->
                                                        <Border Height="3" CornerRadius="1.5" HorizontalAlignment="Left"
                                                                Width="65">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="{Binding TrackFillColor}" />
                                                            </Border.Background>
                                                        </Border>
                                                        <!-- Peak meter hint -->
                                                        <Border Height="2" CornerRadius="1" HorizontalAlignment="Left"
                                                                Width="50" Margin="0,-4,0,0" Opacity="0.5">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="{Binding PeakMeterColor}" />
                                                            </Border.Background>
                                                        </Border>
                                                        <!-- Thumb -->
                                                        <Border Width="10" Height="10" CornerRadius="5" HorizontalAlignment="Left"
                                                                Margin="60,0,0,0">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="{Binding ThumbColor}" />
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <!-- Theme name + category -->
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                                <TextBlock Text="{Binding Category}" FontSize="10" Opacity="0.45"
                                                           Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- TAB 2: CUSTOM — Color swatches + My Themes         -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <StackPanel x:Name="TabPanelCustom">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="2">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Color Swatches Card -->
                        <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                                Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                            Background="{StaticResource BT.SurfaceBrush}">
                                        <TextBlock Text="&#xE2B1;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Static resx:Resources.SettingsColorPalette}" FontSize="15" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static resx:Resources.SettingsColorPaletteDesc}"
                                                   Style="{StaticResource BodySubText}" FontSize="12" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Slider Colors -->
                                <TextBlock Text="{x:Static resx:Resources.SettingsSliderColors}" FontSize="13" Margin="0,0,0,8"
                                           Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                                MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="Thumb"
                                                BorderThickness="3" BorderBrush="#30FFFFFF" RenderTransformOrigin="0.5,0.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect">
                                                        <Setter.Value><DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" /></Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding SliderThumbColor}" />
                                            </Border.Background>
                                            <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                        </Border>
                                        <TextBlock Text="{x:Static resx:Resources.ColorLabelThumb}" FontSize="12" Margin="0,6,0,0"
                                                   HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                                MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="TrackFill"
                                                BorderThickness="3" BorderBrush="#30FFFFFF" RenderTransformOrigin="0.5,0.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect">
                                                        <Setter.Value><DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" /></Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding SliderTrackFillColor}" />
                                            </Border.Background>
                                            <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                        </Border>
                                        <TextBlock Text="{x:Static resx:Resources.ColorLabelFill}" FontSize="12" Margin="0,6,0,0"
                                                   HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                                MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="TrackBackground"
                                                BorderThickness="3" BorderBrush="#30FFFFFF" RenderTransformOrigin="0.5,0.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect">
                                                        <Setter.Value><DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" /></Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding SliderTrackBackgroundColor}" />
                                            </Border.Background>
                                            <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                        </Border>
                                        <TextBlock Text="{x:Static resx:Resources.ColorLabelTrackBg}" FontSize="12" Margin="0,6,0,0"
                                                   HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                                MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="PeakMeter"
                                                BorderThickness="3" BorderBrush="#30FFFFFF" RenderTransformOrigin="0.5,0.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect">
                                                        <Setter.Value><DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" /></Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding PeakMeterColor}" />
                                            </Border.Background>
                                            <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                        </Border>
                                        <TextBlock Text="{x:Static resx:Resources.ColorLabelPeakMeter}" FontSize="12" Margin="0,6,0,0"
                                                   HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Window Colors -->
                                <TextBlock Text="{x:Static resx:Resources.SettingsWindowColors}" FontSize="13" Margin="0,4,0,8"
                                           Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                                MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="WindowBackground"
                                                BorderThickness="3" BorderBrush="#30FFFFFF" RenderTransformOrigin="0.5,0.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect">
                                                        <Setter.Value><DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" /></Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding WindowBackgroundColor}" />
                                            </Border.Background>
                                            <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                        </Border>
                                        <TextBlock Text="{x:Static resx:Resources.ColorLabelWindowBg}" FontSize="12" Margin="0,6,0,0"
                                                   HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                                MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="TextColor"
                                                BorderThickness="3" BorderBrush="#30FFFFFF" RenderTransformOrigin="0.5,0.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect">
                                                        <Setter.Value><DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" /></Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding TextColorValue}" />
                                            </Border.Background>
                                            <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                        </Border>
                                        <TextBlock Text="{x:Static resx:Resources.ColorLabelText}" FontSize="12" Margin="0,6,0,0"
                                                   HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                                MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="AccentGlow"
                                                BorderThickness="3" BorderBrush="#30FFFFFF" RenderTransformOrigin="0.5,0.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect">
                                                        <Setter.Value><DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" /></Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding AccentGlowColor}" />
                                            </Border.Background>
                                            <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                        </Border>
                                        <TextBlock Text="{x:Static resx:Resources.ColorLabelGlow}" FontSize="12" Margin="0,6,0,0"
                                                   HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Reset Button -->
                                <Border Height="36" HorizontalAlignment="Left" CornerRadius="6" Cursor="Hand"
                                        Background="{StaticResource BT.SurfaceBrush}" 
                                        BorderThickness="1" BorderBrush="{StaticResource BT.StrokeMidBrush}"
                                        MouseLeftButtonDown="ResetButton_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BT.HoverBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BT.HoverBorderBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                                   Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                        <TextBlock Text="{x:Static resx:Resources.SettingsResetToDefault}" FontSize="13" VerticalAlignment="Center"
                                                   Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- My Themes Card -->
                        <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                                Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                            <StackPanel>
                                <!-- Header with overflow menu -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                                Background="{StaticResource BT.SurfaceBrush}">
                                            <TextBlock Text="&#xE1F6;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Static resx:Resources.SettingsMyThemes}" FontSize="15" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Static resx:Resources.SettingsMyThemesDesc}"
                                                       Style="{StaticResource BodySubText}" FontSize="12" />
                                        </StackPanel>
                                    </StackPanel>
                                     <!-- Overflow "..." button -->
                                    <Border Grid.Column="2" x:Name="OverflowButton" Width="32" Height="32" CornerRadius="8" Cursor="Hand"
                                            MouseLeftButtonDown="OverflowMenu_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BT.SurfaceBrush}" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BT.HoverBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7" />
                                    </Border>
                                    <!-- Overflow Popup -->
                                    <Popup PlacementTarget="{Binding ElementName=OverflowButton}" Placement="Bottom"
                                           StaysOpen="False" IsOpen="{Binding IsOverflowOpen, Mode=TwoWay}"
                                           AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border Background="#E0202020" CornerRadius="8" Padding="4"
                                                BorderBrush="#40FFFFFF" BorderThickness="1"
                                                Margin="0,4,0,0">
                                            <StackPanel Width="180">
                                                <!-- Copy to clipboard -->
                                                <Border Height="34" CornerRadius="4" Cursor="Hand" Margin="2"
                                                        MouseLeftButtonDown="ExportTheme_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                   VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.7" />
                                                         <TextBlock Text="{x:Static resx:Resources.SettingsCopyToClipboard}" FontSize="12" VerticalAlignment="Center" Foreground="White" />
                                                    </StackPanel>
                                                </Border>
                                                <!-- Paste from clipboard -->
                                                <Border Height="34" CornerRadius="4" Cursor="Hand" Margin="2"
                                                        MouseLeftButtonDown="ImportTheme_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                   VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.7" />
                                                         <TextBlock Text="{x:Static resx:Resources.SettingsPasteFromClipboard}" FontSize="12" VerticalAlignment="Center" Foreground="White" />
                                                    </StackPanel>
                                                </Border>
                                                <!-- Separator -->
                                                <Border Height="1" Background="{StaticResource BT.SurfaceBrush}" Margin="8,3" />
                                                <!-- Export .bttheme -->
                                                <Border Height="34" CornerRadius="4" Cursor="Hand" Margin="2"
                                                        MouseLeftButtonDown="ExportThemeToFile_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                   VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.7" />
                                                         <TextBlock Text="{x:Static resx:Resources.SettingsExportBttheme}" FontSize="12" VerticalAlignment="Center" Foreground="White" />
                                                    </StackPanel>
                                                </Border>
                                                <!-- Import .bttheme -->
                                                <Border Height="34" CornerRadius="4" Cursor="Hand" Margin="2"
                                                        MouseLeftButtonDown="ImportThemeFromFile_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                   VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.7" />
                                                         <TextBlock Text="{x:Static resx:Resources.SettingsImportBttheme}" FontSize="12" VerticalAlignment="Center" Foreground="White" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- Custom themes list -->
                                <ItemsControl ItemsSource="{Binding CustomThemes}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="36" MinWidth="110" Margin="0,0,6,6" CornerRadius="18"
                                                    Cursor="Hand" MouseLeftButtonDown="ThemeCard_Click" Tag="{Binding}"
                                                    Background="#18FFFFFF" BorderThickness="1.5" BorderBrush="#25FFFFFF">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#28FFFFFF" />
                                                                <Setter Property="BorderBrush" Value="#50FFFFFF" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,10,0">
                                                    <Grid Width="22" Height="22" Margin="0,0,8,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Row="0" Grid.Column="0" Width="9" Height="9" CornerRadius="4.5">
                                                            <Border.Background><SolidColorBrush Color="{Binding ThumbColor}" /></Border.Background>
                                                        </Border>
                                                        <Border Grid.Row="0" Grid.Column="1" Width="9" Height="9" CornerRadius="4.5">
                                                            <Border.Background><SolidColorBrush Color="{Binding TrackFillColor}" /></Border.Background>
                                                        </Border>
                                                        <Border Grid.Row="1" Grid.Column="0" Width="9" Height="9" CornerRadius="4.5">
                                                            <Border.Background><SolidColorBrush Color="{Binding TrackBackgroundColor}" /></Border.Background>
                                                        </Border>
                                                        <Border Grid.Row="1" Grid.Column="1" Width="9" Height="9" CornerRadius="4.5">
                                                            <Border.Background><SolidColorBrush Color="{Binding PeakMeterColor}" /></Border.Background>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                               FontSize="12"
                                                               Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                                    <Border Width="18" Height="18" CornerRadius="9" Margin="8,0,0,0"
                                                            Background="{StaticResource BT.DangerDimBrush}" Cursor="Hand"
                                                            MouseLeftButtonDown="DeleteCustomTheme_Click" Tag="{Binding}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#50FF4444" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource BT.DangerBrush}" />
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty state text (visible when no custom themes) -->
                                <TextBlock Text="{x:Static resx:Resources.SettingsNoSavedThemes}"
                                           FontSize="12" Opacity="0.45" Margin="0,2,0,8" FontStyle="Italic"
                                           Theme:Brush.Foreground="Theme=Text, HighContrast=Text">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CustomThemes.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Save current as new theme -->
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Grid Width="180" Height="30">
                                        <TextBox Padding="6,4" FontSize="12"
                                                 Text="{Binding NewThemeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="{StaticResource BT.SurfaceBrush}" Foreground="White" 
                                                 BorderBrush="{StaticResource BT.StrokeMidBrush}"
                                                 x:Name="ThemeNameBox" />
                                        <TextBlock Text="{x:Static resx:Resources.SettingsThemeNamePlaceholder}" FontSize="12" Padding="8,6" IsHitTestVisible="False"
                                                   Foreground="#50FFFFFF" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=ThemeNameBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Border Height="30" Margin="8,0,0,0" CornerRadius="6" Cursor="Hand" Padding="12,0"
                                            MouseLeftButtonDown="SaveCustomTheme_Click"
                                            Background="{StaticResource BT.SurfaceBrush}"
                                            BorderThickness="1" BorderBrush="{StaticResource BT.StrokeMidBrush}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BT.HoverBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE105;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                                       Foreground="{StaticResource BT.SuccessBrush}" />
                                            <TextBlock Text="{x:Static resx:Resources.SettingsSaveTheme}" FontSize="12" VerticalAlignment="Center"
                                                       Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:EarTrumpetLegacySettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                <!-- Startup -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsStartup}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsStartupDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <CheckBox HorizontalAlignment="Left"
                                  Content="{x:Static resx:Resources.SettingsRunAtStartup}"
                                  IsChecked="{Binding RunAtStartup, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <!-- Tray Icon -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE825;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsTrayIcon}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsTrayIconDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <CheckBox HorizontalAlignment="Left"
                                  Content="{x:Static resx:Resources.SettingsUseLegacyEarTrumpetIcon}"
                                  IsChecked="{Binding UseLegacyIcon, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>

        <!-- Media Popup Settings Page -->
        <DataTemplate DataType="{x:Type vm:EarTrumpetMediaPopupSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                    <!-- SECTION: Enable Media Popup -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="{StaticResource BT.SurfaceBrush}">
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resx:Resources.SettingsMediaPopup}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsMediaPopupDesc}"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox Content="{x:Static resx:Resources.SettingsEnableMediaPopup}"
                                      IsChecked="{Binding MediaPopupEnabled, Mode=TwoWay}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Interaction (merged Timing + Behavior) -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window"
                            IsEnabled="{Binding MediaPopupEnabled}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="{StaticResource BT.SurfaceBrush}">
                                    <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resx:Resources.SettingsInteraction}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsInteractionDesc}"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Hover delay slider -->
                            <TextBlock Text="{x:Static resx:Resources.SettingsHoverDelay}" FontSize="13" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="0.5s" Style="{StaticResource BodySubText}"
                                           VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Slider Grid.Column="1" Minimum="0.5" Maximum="5"
                                        Value="{Binding HoverDelay, Mode=TwoWay}"
                                        SmallChange="0.01" LargeChange="0.1" IsSnapToTickEnabled="False" />
                                <TextBlock Grid.Column="2" Text="5s" Style="{StaticResource BodySubText}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <Border Grid.Column="3" Padding="8,4" CornerRadius="6" Background="{StaticResource BT.StrokeMidBrush}"
                                        HorizontalAlignment="Right" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding HoverDelayText}" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" FontSize="13" />
                                </Border>
                            </Grid>

                            <!-- Separator -->
                            <Border Height="1" Background="{StaticResource BT.StrokeBrush}" Margin="0,0,0,14" />

                            <!-- Behavior options -->
                            <CheckBox Content="{x:Static resx:Resources.SettingsOnlyWhenPlaying}"
                                      IsChecked="{Binding ShowOnlyWhenPlaying, Mode=TwoWay}" Margin="0,0,0,8" />
                            <CheckBox Content="{x:Static resx:Resources.SettingsRememberExpanded}"
                                      IsChecked="{Binding RememberExpanded, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Visual Effects + Preview -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window"
                            IsEnabled="{Binding MediaPopupEnabled}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="{StaticResource BT.SurfaceBrush}">
                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resx:Resources.SettingsVisualEffects}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsVisualEffectsDesc}"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Live preview of blur effect -->
                            <Border CornerRadius="8" Height="80" Margin="0,0,0,16"
                                    ClipToBounds="True" Background="{StaticResource BT.StrokeMidBrush}">
                                <Grid>
                                    <!-- Simulated album art background with blur -->
                                    <Border CornerRadius="8">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF6B4E9B" Offset="0"/>
                                                <GradientStop Color="#FF2E86AB" Offset="0.5"/>
                                                <GradientStop Color="#FFA23B72" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <BlurEffect Radius="{Binding BlurRadius}" />
                                        </Border.Effect>
                                    </Border>
                                    <!-- Overlay content preview -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.9">
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                   HorizontalAlignment="Center" Foreground="White" />
                                        <TextBlock Text="{x:Static resx:Resources.ColorLabelPreview}" FontSize="12" HorizontalAlignment="Center"
                                                   Foreground="White" Opacity="0.7" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Blur slider -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static resx:Resources.SettingsBlurNone}" Style="{StaticResource BodySubText}"
                                           VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Slider Grid.Column="1" Minimum="0" Maximum="30"
                                        Value="{Binding BlurRadius, Mode=TwoWay}"
                                        SmallChange="1" LargeChange="5" IsSnapToTickEnabled="False" />
                                <TextBlock Grid.Column="2" Text="{x:Static resx:Resources.SettingsBlurMax}" Style="{StaticResource BodySubText}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <Border Grid.Column="3" Padding="8,4" CornerRadius="6" Background="{StaticResource BT.StrokeMidBrush}"
                                        HorizontalAlignment="Right" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding BlurRadiusText}" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" FontSize="13" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

            </StackPanel>
        </DataTemplate>

        <!-- Volume Profiles Settings Page -->
        <DataTemplate DataType="{x:Type vm:EarTrumpetVolumeProfilesSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                <!-- SECTION: Save Current Volumes -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource BT.SectionIcon}">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsSaveCurrentVolumes}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsSaveCurrentVolumesDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding NewProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,6" FontSize="13" VerticalContentAlignment="Center"
                                     Theme:Brush.Foreground="Theme=Text, HighContrast=Text"
                                     Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="BorderBrush" Value="{StaticResource BT.HoverBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource BT.SelectedBorderBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Border Grid.Column="1" Height="32" Margin="8,0,0,0" CornerRadius="6" Cursor="Hand" Padding="16,0"
                                    Background="{StaticResource BT.StrokeMidBrush}" BorderThickness="1" BorderBrush="{StaticResource BT.HoverBorderBrush}"
                                    MouseLeftButtonDown="SaveProfile_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BT.HoverBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                               Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsProfileSave}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION: Saved Profiles -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource BT.SectionIcon}">
                                <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsSavedProfiles}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsSavedProfilesDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Profile list -->
                        <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                 MaxHeight="200" Margin="0,8,0,0"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#80FFFFFF" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock FontSize="12" Foreground="#80FFFFFF">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} device(s) | {1}">
                                                        <Binding Path="Devices.Count" />
                                                        <Binding Path="CreatedAt" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,4" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="0,1">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Selected profile details -->
                        <TextBlock Text="{Binding SelectedProfileDetails}" FontSize="12" Foreground="#60FFFFFF"
                                   Margin="0,8,0,0" Visibility="{Binding HasSelectedProfile, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Border Style="{StaticResource BT.ActionButton}" MouseLeftButtonDown="ApplyProfile_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                               Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsProfileApply}" FontSize="12" VerticalAlignment="Center"
                                               Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource BT.ActionButton}" Margin="8,0,0,0" MouseLeftButtonDown="DeleteProfile_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                               Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsProfileDelete}" FontSize="12" VerticalAlignment="Center"
                                               Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource BT.ActionButton}" Margin="8,0,0,0" MouseLeftButtonDown="ExportProfile_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                               Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsProfileExport}" FontSize="12" VerticalAlignment="Center"
                                               Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource BT.ActionButton}" Margin="8,0,0,0" MouseLeftButtonDown="ImportProfile_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                               Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsProfileImport}" FontSize="12" VerticalAlignment="Center"
                                               Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:EarTrumpetAboutPageViewModel}">
            <StackPanel Margin="0,0,0,24">
                <!-- App identity header -->
                <StackPanel Margin="12,24,12,16" Orientation="Horizontal">
                    <Image Width="48"
                           Height="48"
                           Margin="0,0,16,0"
                           Source="/BetterTrumpet;component/Assets/icon.png"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="26" FontWeight="SemiBold" Text="BetterTrumpet" />
                        <TextBlock FontSize="12" Opacity="0.7" Text="{Binding AboutText}" />
                    </StackPanel>
                </StackPanel>

                <!-- Attribution -->
                <StackPanel Margin="12,0,12,20">
                    <TextBlock Style="{StaticResource BodyText}"
                               Text="{x:Static resx:Resources.ForkAttributionText}" />
                    <TextBlock Style="{StaticResource BodyText}"
                               Opacity="0.7"
                               Text="&#169; 2026 xmn" />
                </StackPanel>

                <!-- Telemetry card -->
                <Border Margin="12,0,12,20"
                        Padding="16"
                        CornerRadius="8"
                        Background="{StaticResource BT.SurfaceBrush}">
                    <StackPanel>
                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                   Margin="0,0,0,4"
                                   Text="{x:Static resx:Resources.PrivacyCheckboxText}" />
                        <TextBlock FontSize="12" Opacity="0.7" TextWrapping="Wrap"
                                   Margin="0,0,0,10"
                                   Text="{Binding TelemetryDescription}" />
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsTelemetryEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Text="{Binding TelemetryStatusText}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Update notifications card -->
                <Border Margin="12,0,12,20"
                        Padding="16"
                        CornerRadius="8"
                        Background="{StaticResource BT.SurfaceBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsUpdates}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsUpdatesDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Channel selector — segmented control -->
                        <TextBlock Text="{x:Static resx:Resources.SettingsNotifyFor}" FontSize="12" Margin="0,0,0,8" Opacity="0.7" />
                        <Border CornerRadius="8" Background="{StaticResource ListItemBackgroundBrush}" Padding="3"
                                BorderBrush="{StaticResource BT.SurfaceBrush}" BorderThickness="1" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- All -->
                                <Border Grid.Column="0" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                        MouseLeftButtonDown="UpdateChannel0_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UpdateChannelIndex}" Value="0">
                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#12FFFFFF" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Static resx:Resources.SettingsUpdateChannelAll}" FontSize="13" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Static resx:Resources.SettingsUpdateChannelAllSub}" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- Minor + Major -->
                                <Border Grid.Column="1" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                        MouseLeftButtonDown="UpdateChannel1_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UpdateChannelIndex}" Value="1">
                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#12FFFFFF" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Static resx:Resources.SettingsUpdateChannelMinor}" FontSize="13" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Static resx:Resources.SettingsUpdateChannelMinorSub}" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- Major only -->
                                <Border Grid.Column="2" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                        MouseLeftButtonDown="UpdateChannel2_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UpdateChannelIndex}" Value="2">
                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#12FFFFFF" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Static resx:Resources.SettingsUpdateChannelMajor}" FontSize="13" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Static resx:Resources.SettingsUpdateChannelMajorSub}" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- None -->
                                <Border Grid.Column="3" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                        MouseLeftButtonDown="UpdateChannel3_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UpdateChannelIndex}" Value="3">
                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#12FFFFFF" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Static resx:Resources.SettingsUpdateChannelNone}" FontSize="13" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Static resx:Resources.SettingsUpdateChannelNoneSub}" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding UpdateChannelDescription}"
                                   FontSize="12" Opacity="0.45" TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <!-- Separator -->
                        <Border Height="1" Background="{StaticResource BT.StrokeBrush}" Margin="0,0,0,12" />

                        <!-- Status + dynamic check/install button -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UpdateStatusText}" FontSize="12" />
                                <TextBlock Text="{Binding LastCheckText}" FontSize="12" Opacity="0.45" Margin="0,2,0,0" />
                            </StackPanel>

                            <!-- Check button (when no update) -->
                            <Border x:Name="CheckUpdateBtn" Grid.Column="1"
                                    MouseLeftButtonDown="CheckUpdate_Click">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource BT.ActionButton}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{x:Static resx:Resources.SettingsCheckUpdate}" FontSize="12" VerticalAlignment="Center" />
                            </Border>

                            <!-- Install button (when update available) — accent glow -->
                            <Border x:Name="InstallUpdateBtn" Grid.Column="1" CornerRadius="8"
                                    Padding="16,8" Cursor="Hand"
                                    MouseLeftButtonDown="InstallUpdate_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#3B9EFF" Offset="0"/>
                                                    <GradientStop Color="#7C4DFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#5BB0FF" Offset="0"/>
                                                            <GradientStop Color="#9C6AFF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Effect>
                                    <DropShadowEffect Color="#3B9EFF" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="InstallBtnText" Text="{x:Static resx:Resources.SettingsInstallUpdate}" FontSize="12"
                                               FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Links -->
                <StackPanel Margin="12,0,12,0">
                    <TextBlock Style="{StaticResource HyperlinkBlock}" Margin="0,0,0,4">
                        <Hyperlink Command="{Binding OpenPrivacyPolicyCommand}">
                            <Run Text="{x:Static resx:Resources.PrivacyPolicyText}" />
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Style="{StaticResource HyperlinkBlock}" Margin="0,0,0,4">
                        <Hyperlink Command="{Binding OpenAboutCommand}">
                            <Run Text="{x:Static resx:Resources.WebsiteText}" />
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Style="{StaticResource HyperlinkBlock}" Margin="0,0,0,4">
                        <Hyperlink Command="{Binding OpenFeedbackCommand}">
                            <Run Text="{x:Static resx:Resources.ContextMenuSendFeedback}" />
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Style="{StaticResource HyperlinkBlock}" Margin="0,0,0,4">
                        <Hyperlink Command="{Binding OpenDiagnosticsCommand}">
                            <Run Text="{x:Static resx:Resources.TroubleshootEarTrumpetText}" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Export & Import settings card -->
                <Border Margin="12,0,12,20"
                        Padding="16"
                        CornerRadius="8"
                        Background="{StaticResource BT.SurfaceBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="{StaticResource BT.SurfaceBrush}">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsExportImport}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static resx:Resources.SettingsExportImportDesc}"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Border Style="{StaticResource BT.ActionButton}" Margin="0,0,8,0"
                                    MouseLeftButtonDown="ExportSettings_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsExportSettings}" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource BT.ActionButton}"
                                    MouseLeftButtonDown="ImportSettings_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{x:Static resx:Resources.SettingsImportSettings}" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Health info (for power users) -->
                <Border Margin="12,20,12,0"
                        Padding="12"
                        CornerRadius="6"
                        Background="#0DFFFFFF">
                    <TextBlock FontSize="12" Opacity="0.45" FontFamily="Consolas"
                               Text="{Binding HealthSummary}" />
                </Border>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsPageHeaderViewModel}">
            <StackPanel Margin="24,16,0,12">
                <TextBlock FontSize="26" FontWeight="SemiBold"
                           Text="{Binding Title}" />
                <TextBlock x:Name="SubtitleText" FontSize="13" Opacity="0.45" Margin="0,2,0,0"
                           Text="{Binding Subtitle}" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Subtitle}" Value="{x:Null}">
                    <Setter TargetName="SubtitleText" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Subtitle}" Value="">
                    <Setter TargetName="SubtitleText" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AddonAboutPageViewModel}">
            <StackPanel Orientation="Vertical">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource BodyText}" Text="{x:Static resx:Resources.AddonNameText}" />
                    <TextBlock Grid.Row="1"
                               Style="{StaticResource BodyText}"
                               Text="{x:Static resx:Resources.PublisherText}" />
                    <TextBlock Grid.Row="2"
                               Style="{StaticResource BodyText}"
                               Text="{x:Static resx:Resources.VersionText}" />

                    <TextBlock Grid.Column="1"
                               Style="{StaticResource BodySubText}"
                               Text="{Binding DisplayName}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Style="{StaticResource BodySubText}"
                               Text="{Binding PublisherName}" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Style="{StaticResource BodySubText}"
                               Text="{Binding Version}" />
                </Grid>
                <TextBlock Style="{StaticResource HyperlinkBlock}"><Hyperlink Command="{Binding OpenHelpLink}">
                        <Run Text="{x:Static resx:Resources.WebsiteText}" />
                    </Hyperlink></TextBlock>

                <TextBlock Style="{StaticResource HeadingText}" Text="{x:Static resx:Resources.AddonUninstallTitle}" />
                <TextBlock Style="{StaticResource BodyText}" Text="{x:Static resx:Resources.AddonUninstallDescriptionText}" />
                <Button Command="{Binding Uninstall}" Content="{x:Static resx:Resources.AddonUninstallButtonText}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsCategoryViewModel}">
            <Grid PreviewMouseRightButtonDown="{Event:HandledBinding}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAd}" Value="True">
                                <Setter Property="Theme:Brush.Background" Value="AcrylicBackgroundFallback" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Polygon HorizontalAlignment="Right"
                         Theme:Brush.Fill="SystemAccent"
                         Points="0,0 40,0 40,40">
                    <Polygon.Style>
                        <Style TargetType="Polygon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAd}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Polygon.Style>
                </Polygon>

                <TextBlock Margin="4,6,4,4"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Theme:Brush.Foreground="ApplicationTextDarkTheme"
                           FontSize="12"
                           Text="&#xE896;">
                    <TextBlock.Style>
                        <Style BasedOn="{StaticResource GlyphTextBlockStyle}" TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAd}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.RowSpan="2"
                               Margin="0,-6,0,0"
                               VerticalAlignment="Center"
                               FontSize="30"
                               Text="{Binding Glyph}">
                        <TextBlock.Style>
                            <Style BasedOn="{StaticResource GlyphTextBlockStyle}" TargetType="TextBlock">
                                <Setter Property="Theme:Brush.Foreground" Value="SystemAccent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAd}" Value="True">
                                        <Setter Property="Theme:Brush.Foreground" Value="DarkGray" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="1"
                               Margin="6,12,0,0"
                               VerticalAlignment="Top"
                               FontSize="15"
                               Text="{Binding Title}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Margin="6,2,8,6"
                               VerticalAlignment="Top"
                               Theme:Brush.Foreground="GrayText"
                               FontSize="12"
                               Text="{Binding Description}"
                               TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </DataTemplate>
        <Style x:Key="SettingsListViewItem" TargetType="{x:Type ListViewItem}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Height" Value="48" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource Windows10FocusVisualStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="true">
                            <ContentPresenter Margin="0"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Theme:Brush.Background" Value="Theme={Theme}ListLow, HighContrast=Highlight" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsListView" TargetType="{x:Type ListView}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="true" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsListViewItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListView}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="true">
                            <ScrollViewer Padding="{TemplateBinding Padding}" Focusable="false">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MainListItem" TargetType="{x:Type ListViewItem}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Height" Value="86" />
            <Setter Property="Width" Value="250" />
            <Setter Property="Margin" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource Windows10FocusVisualStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="2"
                                SnapsToDevicePixels="true">

                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />

                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Theme:Brush.BorderBrush" Value="Light=LightBaseMediumLow/0.12, Dark=DarkBaseMediumLow/0.12, HighContrast=Highlight" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MainList" TargetType="{x:Type ListView}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="true" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource MainListItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListView}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="true">
                            <ScrollViewer Padding="{TemplateBinding Padding}" Focusable="false">
                                <ItemsPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <!--  Background  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Name="AcrylicBackgroundActive" Theme:Brush.Background="AcrylicBackground" />
            <Border Name="AcrylicBackgroundWhileDragging">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Theme:Brush.Background" Value="AcrylicBackgroundFallback" />
                        <Setter Property="Opacity" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=WindowRoot, Path=(Theme:AcrylicBrush.IsSuppressed)}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard Name="IsSuppressed_Enter_AnimationsOn">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="00:00:00" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard Name="IsSuppressed_Exit_AnimationsOn">
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames BeginTime="0:0:0"
                                                                           Storyboard.TargetProperty="Opacity"
                                                                           Duration="0:00:00.25">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="0" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Border Name="AcrylicBackgroundInactive">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Theme:Brush.Background" Value="AcrylicBackgroundFallback" />
                        <Setter Property="Opacity" Value="1" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Source={StaticResource ThemeManager}, Path=AnimationsEnabled}" Value="True" />
                                    <Condition Binding="{Binding ElementName=WindowRoot, Path=IsActive}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.EnterActions>
                                    <StopStoryboard BeginStoryboardName="IsActive_Exit_AnimationsOff" />
                                    <StopStoryboard BeginStoryboardName="IsActive_Enter_AnimationsOff" />
                                    <BeginStoryboard Name="IsActive_Enter_AnimationsOn">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1"
                                                             To="0"
                                                             Duration="00:00:00.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.EnterActions>
                                <MultiDataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="IsActive_Enter_AnimationsOff" />
                                    <StopStoryboard BeginStoryboardName="IsActive_Exit_AnimationsOff" />
                                    <BeginStoryboard Name="IsActive_Exit_AnimationsOn">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="00:00:00.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.ExitActions>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Source={StaticResource ThemeManager}, Path=AnimationsEnabled}" Value="False" />
                                    <Condition Binding="{Binding ElementName=WindowRoot, Path=IsActive}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.EnterActions>
                                    <StopStoryboard BeginStoryboardName="IsActive_Enter_AnimationsOn" />
                                    <StopStoryboard BeginStoryboardName="IsActive_Exit_AnimationsOn" />
                                    <BeginStoryboard Name="IsActive_Enter_AnimationsOff">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1"
                                                             To="0"
                                                             Duration="00:00:00" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.EnterActions>
                                <MultiDataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="IsActive_Exit_AnimationsOn" />
                                    <StopStoryboard BeginStoryboardName="IsActive_Enter_AnimationsOn" />
                                    <BeginStoryboard Name="IsActive_Exit_AnimationsOff">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="00:00:00" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.ExitActions>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Border Theme:Brush.Background="Background">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Selected}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                        <Setter Property="Visibility" Value="Collapsed" />
                    </Style>
                </Border.Style>
            </Border>
            <Border Grid.Column="1" Theme:Brush.Background="Background" />
        </Grid>
        <DockPanel LastChildFill="True">
            <!--  TitleBar  -->
            <Grid DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="BackButton"
                        Command="{Binding Backstack.GoBack}"
                        FontSize="13">
                    <Button.Style>
                        <Style BasedOn="{StaticResource CaptionButtonStyle}" TargetType="Button">
                            <Setter Property="IsEnabled" Value="False" />
                            <Setter Property="Content" Value="&#xE72B;" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Backstack.CanGoBack}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Source={x:Static datamodel:SystemSettings.IsRTL}}" Value="True">
                                    <Setter Property="Content" Value="&#xE72A;" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Theme:Brush.Foreground" Value="Theme=ApplicationTextDarkTheme, HighContrast=HighlightText" />
                                    <Setter Property="Theme:Brush.Background" Value="Theme=SystemAccent, HighContrast=Highlight" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Theme:Brush.Foreground" Value="Theme=ApplicationTextDarkTheme, HighContrast=HighlightText" />
                                    <Setter Property="Theme:Brush.Background" Value="Theme=SystemAccent{Theme}1, HighContrast=Highlight" />
                                </Trigger>
                                <DataTrigger Binding="{Binding Dialog}" Value="{x:Null}">
                                    <Setter Property="IsEnabled" Value="True" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Grid.Column="1"
                           Margin="14,0,0,0"
                           Text="{Binding Title}"
                           TextAlignment="Left" />
                <Button x:Name="MinimizeButton"
                        Grid.Column="2"
                        Style="{StaticResource MinimizeButton}" />
                <Button x:Name="MaximizeRestoreButton"
                        Grid.Column="3"
                        Style="{StaticResource MaximizeButton}" />
                <Button x:Name="CloseButton"
                        Grid.Column="4"
                        Style="{StaticResource CloseButtonStyle}" />
            </Grid>
            <Grid>
                <!--  Main  -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Selected}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="90" />
                        <RowDefinition Height="46" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Style="{StaticResource HeadingText}"
                               Text="{x:Static resx:Resources.SettingsTitle}" />
                    <ComboBox Grid.Row="1"
                              Width="332"
                              Height="32"
                              Margin="0"
                              VerticalContentAlignment="Center"
                              b:ComboBoxEx.SearchItemsSource="{Binding}" />
                    <ctl:ListView Grid.Row="2"
                                  ItemInvoked="{Event:Binding OnInvoked}"
                                  ItemsSource="{Binding Categories}"
                                  Style="{StaticResource MainList}">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Margin="0,24" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ctl:ListView>
                </Grid>
                <!--  Subview  -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Selected}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Visibility" Value="Visible" />
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.Resources>
                            <CollectionViewSource x:Key="cvs"
                                                  IsLiveGroupingRequested="True"
                                                  Source="{Binding Selected.Pages}">
                                <CollectionViewSource.GroupDescriptions>
                                    <PropertyGroupDescription PropertyName="GroupName" />
                                </CollectionViewSource.GroupDescriptions>
                            </CollectionViewSource>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="16" />
                            <RowDefinition Height="48" />
                            <RowDefinition Height="48" />
                            <RowDefinition Height="48" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="1"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                AutomationProperties.Name="{x:Static resx:Resources.HomeButtonText}"
                                Command="{Binding GoHome}"
                                Style="{StaticResource InvisibleButtonStyle}">
                            <Button.Content>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Margin="16,0,4,0"
                                               FontSize="16"
                                               Text="&#xE10F;">
                                        <TextBlock.Style>
                                            <Style BasedOn="{StaticResource GlyphTextBlockStyle}" TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Theme:Brush.Foreground" Value="Theme=Text, HighContrast=HighlightText" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               FontSize="15"
                                               Text="{x:Static resx:Resources.HomeButtonText}">
                                        <TextBlock.Style>
                                            <Style BasedOn="{StaticResource BodyText}" TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Theme:Brush.Foreground" Value="Theme=Text, HighContrast=HighlightText" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button.Content>
                        </Button>
                        <ComboBox Grid.Row="2"
                                  Height="32"
                                  Margin="16,2,16,0"
                                  VerticalContentAlignment="Center"
                                  b:ComboBoxEx.SearchItemsSource="{Binding}" />
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Margin="16,0,0,0"
                                        FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="{Binding Selected.Title}" />
                            <ItemsControl Grid.Column="1"
                                          IsTabStop="False"
                                          ItemsSource="{Binding Selected.Toolbar}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ToolbarItemViewModel}">
                                        <Button VerticalAlignment="Center"
                                                HorizontalContentAlignment="Stretch"
                                                AutomationProperties.Name="{Binding DisplayName}"
                                                BorderThickness="0"
                                                Command="{Binding Command}"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                ToolTipService.ToolTip="{Binding DisplayName}">
                                            <TextBlock FontSize="{Binding GlyphFontSize}"
                                                       Style="{StaticResource GlyphTextBlockStyle}"
                                                       Text="{Binding Glyph}" />
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                        <ListView Grid.Row="4"
                                  IsSynchronizedWithCurrentItem="True"
                                  ItemsSource="{Binding Source={StaticResource cvs}}"
                                  ScrollViewer.CanContentScroll="False"
                                  SelectedItem="{Binding Selected.Selected, Mode=TwoWay}"
                                  Style="{StaticResource SettingsListView}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="selectedIndicator"
                                                Width="4"
                                                Height="24">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Theme:Brush.Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Theme:Brush.Background" Value="SystemAccent" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   HorizontalAlignment="Center"
                                                   FontSize="16"
                                                   Text="{Binding Glyph}">
                                            <TextBlock.Style>
                                                <Style BasedOn="{StaticResource GlyphTextBlockStyle}" TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Theme:Brush.Foreground" Value="Theme=Text, HighContrast=HighlightText" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2"
                                                   Margin="4,0,12,0"
                                                   FontSize="15"
                                                   Text="{Binding Title}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Theme:Brush.Foreground" Value="Theme=Text, HighContrast=HighlightText" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="16,12,0,6"
                                                       Theme:Brush.Foreground="GrayText"
                                                       FontSize="15"
                                                       Text="{Binding Name}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Name}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListView.GroupStyle>
                        </ListView>
                    </Grid>
                    <Border Grid.Column="1" Theme:Brush.BorderBrush="Theme=Transparent, HighContrast=Text">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Source={StaticResource ThemeManager}, Path=IsHighContrast}" Value="True">
                                        <Setter Property="BorderThickness" Value="1,0,0,0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ContentControl Content="{Binding Selected.Selected.Header}" IsTabStop="False" />
                            <ScrollViewer x:Name="PageScrollViewer"
                                          Grid.Row="1"
                                          b:ScrollViewerEx.ScrollToTopOnChanged="{Binding Selected.Selected}"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ContentControl x:Name="PageContent"
                                                Margin="12,0,0,0"
                                                Content="{Binding Selected.Selected}"
                                                FocusVisualStyle="{x:Null}"
                                                Focusable="False"
                                                IsTabStop="False" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                <!--  Dialog  -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Dialog}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid Background="LightGray" Opacity="0.5" />
                    <Border MinWidth="300"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Theme:Brush.BorderBrush="SystemAccent"
                            BorderThickness="1">
                        <Grid Theme:Brush.Background="Background">
                            <Grid Margin="12" KeyboardNavigation.TabNavigation="Cycle">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.ColumnSpan="2" Orientation="Vertical">
                                    <TextBlock Margin="12,12,12,0"
                                               Style="{StaticResource HeadingText}"
                                               Text="{Binding Dialog.Title}" />
                                    <TextBlock Margin="12,12,12,24"
                                               Style="{StaticResource BodyText}"
                                               Text="{Binding Dialog.Description}" />
                                </StackPanel>
                                <Button Grid.Row="1"
                                        Margin="12,12,2,12"
                                        HorizontalAlignment="Stretch"
                                        Theme:Brush.Background="SystemAccent"
                                        Theme:Brush.Foreground="Light=ApplicationTextDarkTheme, Dark=Text"
                                        Command="{Binding Dialog.Button1Command}"
                                        Content="{Binding Dialog.Button1Text}" />
                                <Button Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="2,12,12,12"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding Dialog.Button2Command}"
                                        Content="{Binding Dialog.Button2Text}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
