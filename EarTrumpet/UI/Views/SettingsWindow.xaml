<Window x:Class="EarTrumpet.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Event="clr-namespace:EarTrumpet.Extensions.EventBinding"
        xmlns:Theme="clr-namespace:EarTrumpet.UI.Themes"
        xmlns:b="clr-namespace:EarTrumpet.UI.Behaviors"
        xmlns:ctl="clr-namespace:EarTrumpet.UI.Controls"
        xmlns:datamodel="clr-namespace:EarTrumpet.DataModel"
        xmlns:local="clr-namespace:EarTrumpet"
        xmlns:resx="clr-namespace:EarTrumpet.Properties"
        xmlns:vm="clr-namespace:EarTrumpet.UI.ViewModels"
        xmlns:helpers="clr-namespace:EarTrumpet.UI.Helpers"
        Name="WindowRoot"
        Title="{Binding Title}"
        Width="800"
        Height="600"
        MinWidth="770"
        MinHeight="320"
        Theme:AcrylicBrush.Background="AcrylicColor_Settings"
        Theme:Options.Source="App"
        b:FrameworkElementEx.DisplaySettingsChanged="{Binding DisplaySettingsChanged}"
        b:FrameworkElementEx.FlowDirection="Auto"
        Background="Transparent"
        Closing="{Event:Binding OnClosing}"
        ResizeMode="CanResize"
        Style="{StaticResource DialogWindowStyle}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <helpers:IntToBoolConverter x:Key="IntToBoolConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:PercentWidthConverter x:Key="PercentWidthConverter" />
        <local:ThumbMarginConverter x:Key="ThumbMarginConverter" />

        <!-- Named brushes: replaces 90+ hardcoded alpha-white colors -->
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#20FFFFFF"/>
        <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#25FFFFFF"/>
        <SolidColorBrush x:Key="HoverBorderBrush" Color="#30FFFFFF"/>
        <SolidColorBrush x:Key="ActiveBorderBrush" Color="#60FFFFFF"/>
        <SolidColorBrush x:Key="PressedBackgroundBrush" Color="#40FFFFFF"/>
        <SolidColorBrush x:Key="DimTextBrush" Color="#80FFFFFF"/>
        <SolidColorBrush x:Key="FaintTextBrush" Color="#60FFFFFF"/>
        <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="#08FFFFFF"/>
        <SolidColorBrush x:Key="ListItemHoverBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="SelectedBorderBrush" Color="#50FFFFFF"/>
        <SolidColorBrush x:Key="DeleteBackgroundBrush" Color="#20FF4444"/>
        <SolidColorBrush x:Key="DeleteTextBrush" Color="#FFFF6666"/>
        <SolidColorBrush x:Key="SuccessAccentBrush" Color="#FF7ED321"/>
        <!-- Brand accent: warm trumpet gold -->
        <Color x:Key="BrandAccentColor">#FFFFC857</Color>
        <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccentColor}"/>
        <SolidColorBrush x:Key="BrandAccentDimBrush" Color="#40FFC857"/>
        <!-- Warning amber for Eco Mode override notice -->
        <SolidColorBrush x:Key="WarningAmberBrush" Color="#FFFFA726"/>
        <SolidColorBrush x:Key="WarningAmberDimBrush" Color="#25FFA726"/>

        <!-- Reusable action button style with hover + pressed states -->
        <Style x:Key="ActionButtonBorder" TargetType="Border">
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource HoverBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section card style -->
        <Style x:Key="SectionCardBorder" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <!-- Section icon style -->
        <Style x:Key="SectionIconBorder" TargetType="Border">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
        </Style>
        <DataTemplate DataType="{x:Type vm:EarTrumpetShortcutsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                <!-- Hotkey card: Open Flyout -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="#15FFFFFF">
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsOpenEarTrumpetText}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12">
                                    <Run Text="Default: " /><Run Text="{Binding DefaultHotKey, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <ContentControl Content="{Binding OpenFlyoutHotkey}" IsTabStop="False" Margin="48,0,0,0" />
                    </StackPanel>
                </Border>

                <!-- Hotkey card: Open Mixer -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="#15FFFFFF">
                                <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsOpenMixerText}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12">
                                    <Run Text="Default: " /><Run Text="{Binding DefaultMixerHotKey, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <ContentControl Content="{Binding OpenMixerHotkey}" IsTabStop="False" Margin="48,0,0,0" />
                    </StackPanel>
                </Border>

                <!-- Hotkey card: Open Settings -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="#15FFFFFF">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resx:Resources.SettingsOpenSettingsText}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12">
                                    <Run Text="Default: " /><Run Text="{Binding DefaultSettingsHotKey, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <ContentControl Content="{Binding OpenSettingsHotkey}" IsTabStop="False" Margin="48,0,0,0" />
                    </StackPanel>
                </Border>

                <!-- Hotkey card: Volume Up/Down -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="#15FFFFFF">
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Absolute Volume" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Direct volume up/down hotkeys"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{x:Static resx:Resources.SettingsAbsoluteVolumeUpText}" FontSize="13" Margin="0,0,0,6" />
                        <ContentControl Content="{Binding AbsoluteVolumeUpHotkey}" IsTabStop="False" Margin="0,0,0,14" />

                        <Border Height="1" Background="#10FFFFFF" Margin="0,0,0,14" />

                        <TextBlock Text="{x:Static resx:Resources.SettingsAbsoluteVolumeDownText}" FontSize="13" Margin="0,0,0,6" />
                        <ContentControl Content="{Binding AbsoluteVolumeDownHotkey}" IsTabStop="False" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EarTrumpetMouseSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="#15FFFFFF">
                                <TextBlock Text="&#xE962;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Scroll Wheel" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Control volume with your mouse wheel"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <CheckBox HorizontalAlignment="Left" Margin="0,0,0,10"
                                  Content="{x:Static resx:Resources.SettingsUseScrollWheelInTray}"
                                  IsChecked="{Binding UseScrollWheelInTray, Mode=TwoWay}"
                                  ToolTip="Scroll your mouse wheel over the tray icon to quickly adjust system volume." />
                        <CheckBox HorizontalAlignment="Left"
                                  Content="{x:Static resx:Resources.SettingsUseGlobalMouseWheelHook}"
                                  IsChecked="{Binding UseGlobalMouseWheelHook, Mode=TwoWay}"
                                  ToolTip="Enables volume control via scroll wheel anywhere on screen when holding a modifier key. May conflict with some applications." />
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EarTrumpetCommunitySettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="#15FFFFFF">
                                <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Volume Scale" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="How volume steps are distributed"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <CheckBox HorizontalAlignment="Left"
                                  Content="{x:Static resx:Resources.SettingsUseLogarithmicVolume}"
                                  IsChecked="{Binding UseLogarithmicVolume, Mode=TwoWay}"
                                  ToolTip="Use logarithmic volume scale for more natural volume control. Lower volumes will have finer adjustment, matching how human hearing perceives loudness changes." />
                        <TextBlock Style="{StaticResource BodySubText}" FontSize="11" Opacity="0.5" Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Text="Logarithmic scale matches human hearing perception — finer control at low volumes, coarser at high." />
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>
        <!-- Performance Settings Page -->
        <DataTemplate DataType="{x:Type vm:EarTrumpetAnimationSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                    <!-- SECTION: Battery Optimization -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xEA94;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Eco Mode" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Save battery by reducing refresh rate"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox Content="Enable Eco Mode (20 FPS)"
                                      IsChecked="{Binding EcoMode, Mode=TwoWay}" Margin="0,8,0,6"
                                      ToolTip="Reduces peak meter refresh rate to 20 FPS, significantly lowering CPU usage. Ideal for laptops or when running on battery power." />
                            <CheckBox Content="Auto-enable when on battery"
                                      IsChecked="{Binding AutoEcoMode, Mode=TwoWay}" Margin="0,0,0,14"
                                      ToolTip="Automatically activates Eco Mode when your device is running on battery to extend battery life." />

                            <Border Padding="10,8" CornerRadius="6" Background="#15FFFFFF">
                                <TextBlock Style="{StaticResource BodySubText}" FontSize="12">
                                    <Run Text="Current refresh rate: " />
                                    <Run Text="{Binding EffectiveFpsText, Mode=OneWay}" FontWeight="SemiBold"
                                         Foreground="{StaticResource BrandAccentBrush}" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Animations -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Animations" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Volume slider transitions"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox Content="Smooth volume animation"
                                      IsChecked="{Binding UseSmoothVolumeAnimation, Mode=TwoWay}" Margin="0,8,0,12"
                                      ToolTip="When enabled, clicking on the volume track will smoothly animate to the target volume instead of jumping instantly. Disable for immediate response." />

                            <StackPanel Orientation="Vertical" Margin="0,0,0,0"
                                        IsEnabled="{Binding UseSmoothVolumeAnimation}">
                                <TextBlock Text="Animation speed" Margin="0,0,0,8" FontSize="13" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Slow" Style="{StaticResource BodySubText}"
                                               VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <Slider Grid.Column="1" Minimum="1" Maximum="10"
                                            Value="{Binding VolumeAnimationSpeed, Mode=TwoWay}"
                                            TickFrequency="1" IsSnapToTickEnabled="True" />
                                    <TextBlock Grid.Column="2" Text="Fast" Style="{StaticResource BodySubText}"
                                               VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Peak Meter -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Peak Meter" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Audio level visualization refresh"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Eco Mode override warning — amber accent -->
                            <Border Padding="12,8" CornerRadius="6" Margin="0,0,0,16"
                                    Background="{StaticResource WarningAmberDimBrush}"
                                    BorderBrush="#40FFA726" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="{StaticResource WarningAmberBrush}" />
                                    <TextBlock FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource WarningAmberBrush}">
                                        <Run Text="Overridden by Eco Mode when active" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Segmented Control for FPS -->
                            <TextBlock Text="Refresh rate" FontSize="13" Margin="0,0,0,10" />
                            <Border CornerRadius="8" Background="#08FFFFFF" Padding="3"
                                    BorderBrush="#15FFFFFF" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 5 FPS -->
                                    <Border Grid.Column="0" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="Fps5Card_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PeakMeterFps}" Value="5">
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#12FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="5 FPS" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="Ultra saver" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- 20 FPS -->
                                    <Border Grid.Column="1" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="Fps20Card_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PeakMeterFps}" Value="20">
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#12FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="20 FPS" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="Battery saver" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- 30 FPS -->
                                    <Border Grid.Column="2" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="Fps30Card_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PeakMeterFps}" Value="30">
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#12FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="30 FPS" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="Balanced" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- 60 FPS -->
                                    <Border Grid.Column="3" Padding="0,8" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="Fps60Card_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PeakMeterFps}" Value="60">
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#12FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="60 FPS" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="Smoothest" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

            </StackPanel>
        </DataTemplate>

        <!-- Appearance Settings Page -->
        <DataTemplate DataType="{x:Type vm:EarTrumpetColorsSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                    <!-- SECTION: Enable Custom Colors -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Custom Colors" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Personalize volume slider appearance"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox Content="Enable custom slider colors"
                                      IsChecked="{Binding UseCustomSliderColors, Mode=TwoWay}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Mini Slider Preview -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window"
                            IsEnabled="{Binding UseCustomSliderColors}">
                        <StackPanel>
                            <TextBlock Text="Preview" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"
                                       Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                            <!-- Realistic flyout preview mimicking the actual app layout -->
                            <Border CornerRadius="8" Padding="0" BorderThickness="1" BorderBrush="#20FFFFFF" ClipToBounds="True">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding WindowBackgroundColor}" />
                                </Border.Background>
                                <StackPanel>
                                    <!-- Row 1: App with slider at ~70% -->
                                    <Grid Height="38" Margin="12,6,12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <!-- App icon -->
                                        <Border Grid.Column="0" Width="20" Height="20" CornerRadius="4"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding SliderTrackFillColor}" Opacity="0.6" />
                                            </Border.Background>
                                            <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding TextColorValue}" />
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>
                                        <!-- Slider track -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                                            <!-- Track background (full width) -->
                                            <Border Height="4" CornerRadius="2">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackBackgroundColor}" />
                                                </Border.Background>
                                            </Border>
                                            <!-- Track fill at 70% -->
                                            <Border Height="4" CornerRadius="2" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource PercentWidthConverter}" ConverterParameter="0.70" FallbackValue="140" />
                                                </Border.Width>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackFillColor}" />
                                                </Border.Background>
                                            </Border>
                                            <!-- Peak meter above track -->
                                            <Border Height="3" CornerRadius="1.5" HorizontalAlignment="Left" Margin="0,-5,0,0" Opacity="0.5">
                                                <Border.Width>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource PercentWidthConverter}" ConverterParameter="0.55" FallbackValue="110" />
                                                </Border.Width>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding PeakMeterColor}" />
                                                </Border.Background>
                                            </Border>
                                            <!-- Thumb -->
                                            <Border Width="14" Height="14" CornerRadius="7" HorizontalAlignment="Left">
                                                <Border.Margin>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource ThumbMarginConverter}" ConverterParameter="0.70" />
                                                </Border.Margin>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderThumbColor}" />
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <!-- Volume number -->
                                        <TextBlock Grid.Column="2" Text="70" FontSize="13" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding TextColorValue}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Row 2: App with slider at ~33% -->
                                    <Grid Height="38" Margin="12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="20" Height="20" CornerRadius="4"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding SliderThumbColor}" Opacity="0.5" />
                                            </Border.Background>
                                            <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding TextColorValue}" />
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                                            <Border Height="4" CornerRadius="2">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackBackgroundColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Height="4" CornerRadius="2" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource PercentWidthConverter}" ConverterParameter="0.33" FallbackValue="66" />
                                                </Border.Width>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackFillColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Width="14" Height="14" CornerRadius="7" HorizontalAlignment="Left">
                                                <Border.Margin>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" 
                                                             Converter="{StaticResource ThumbMarginConverter}" ConverterParameter="0.33" />
                                                </Border.Margin>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderThumbColor}" />
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Column="2" Text="33" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding TextColorValue}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Row 3: Muted app at 100% -->
                                    <Grid Height="38" Margin="12,0,12,6" Opacity="0.45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="20" Height="20" CornerRadius="4"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding PeakMeterColor}" Opacity="0.4" />
                                            </Border.Background>
                                            <TextBlock Text="&#xE74F;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding TextColorValue}" />
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                                            <Border Height="4" CornerRadius="2">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackBackgroundColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Height="4" CornerRadius="2" HorizontalAlignment="Stretch">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderTrackFillColor}" />
                                                </Border.Background>
                                            </Border>
                                            <Border Width="14" Height="14" CornerRadius="7" HorizontalAlignment="Right">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SliderThumbColor}" />
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Column="2" Text="100" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding TextColorValue}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Theme Presets (Grouped by Category) -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window"
                            IsEnabled="{Binding UseCustomSliderColors}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Theme Presets" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Grouped color schemes with live preview"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding GroupedThemes}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <!-- Category header -->
                                            <TextBlock Text="{Binding Key}" FontSize="12" FontWeight="SemiBold" 
                                                       Margin="0,0,0,8" Opacity="0.5"
                                                       Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                            <!-- Theme pills in this category -->
                                            <ItemsControl ItemsSource="{Binding}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Height="36" MinWidth="110" Margin="0,0,6,6" CornerRadius="18"
                                                                Cursor="Hand" MouseLeftButtonDown="ThemeCard_Click" Tag="{Binding}"
                                                                Background="#18FFFFFF" BorderThickness="1.5" BorderBrush="#25FFFFFF">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#28FFFFFF" />
                                                                            <Setter Property="BorderBrush" Value="#50FFFFFF" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,12,0">
                                                                <Grid Width="22" Height="22" Margin="0,0,8,0">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*" />
                                                                        <RowDefinition Height="*" />
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Row="0" Grid.Column="0" Width="9" Height="9" CornerRadius="4.5">
                                                                        <Border.Background><SolidColorBrush Color="{Binding ThumbColor}" /></Border.Background>
                                                                    </Border>
                                                                    <Border Grid.Row="0" Grid.Column="1" Width="9" Height="9" CornerRadius="4.5">
                                                                        <Border.Background><SolidColorBrush Color="{Binding TrackFillColor}" /></Border.Background>
                                                                    </Border>
                                                                    <Border Grid.Row="1" Grid.Column="0" Width="9" Height="9" CornerRadius="4.5">
                                                                        <Border.Background><SolidColorBrush Color="{Binding TrackBackgroundColor}" /></Border.Background>
                                                                    </Border>
                                                                    <Border Grid.Row="1" Grid.Column="1" Width="9" Height="9" CornerRadius="4.5">
                                                                        <Border.Background><SolidColorBrush Color="{Binding PeakMeterColor}" /></Border.Background>
                                                                    </Border>
                                                                </Grid>
                                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                                           FontSize="12" FontWeight="Medium"
                                                                           Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: My Themes (Custom saved) -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window"
                            IsEnabled="{Binding UseCustomSliderColors}">
                        <StackPanel>
                            <!-- Header with inline toolbar -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                            Background="#15FFFFFF">
                                        <TextBlock Text="&#xE1F6;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="My Themes" FontSize="15" FontWeight="SemiBold" />
                                        <TextBlock Text="Saved custom color schemes"
                                                   Style="{StaticResource BodySubText}" FontSize="12" />
                                    </StackPanel>
                                </StackPanel>
                                <!-- Compact toolbar: icons only -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="30" Height="30" CornerRadius="6" Cursor="Hand" Margin="0,0,4,0"
                                            MouseLeftButtonDown="ExportTheme_Click" ToolTip="Copy to clipboard">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#10FFFFFF" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#25FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7" />
                                    </Border>
                                    <Border Width="30" Height="30" CornerRadius="6" Cursor="Hand" Margin="0,0,4,0"
                                            MouseLeftButtonDown="ImportTheme_Click" ToolTip="Paste from clipboard">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#10FFFFFF" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#25FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7" />
                                    </Border>
                                    <Border Width="30" Height="30" CornerRadius="6" Cursor="Hand" Margin="0,0,4,0"
                                            MouseLeftButtonDown="ExportThemeToFile_Click" ToolTip="Export .bttheme file">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#10FFFFFF" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#25FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7" />
                                    </Border>
                                    <Border Width="30" Height="30" CornerRadius="6" Cursor="Hand"
                                            MouseLeftButtonDown="ImportThemeFromFile_Click" ToolTip="Import .bttheme file">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#10FFFFFF" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#25FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Custom themes list -->
                            <ItemsControl ItemsSource="{Binding CustomThemes}" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="36" MinWidth="110" Margin="0,0,6,6" CornerRadius="18"
                                                Cursor="Hand" MouseLeftButtonDown="ThemeCard_Click" Tag="{Binding}"
                                                Background="#18FFFFFF" BorderThickness="1.5" BorderBrush="#25FFFFFF">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#28FFFFFF" />
                                                            <Setter Property="BorderBrush" Value="#50FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,10,0">
                                                <!-- 4-color swatch -->
                                                <Grid Width="22" Height="22" Margin="0,0,8,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Row="0" Grid.Column="0" Width="9" Height="9" CornerRadius="4.5">
                                                        <Border.Background><SolidColorBrush Color="{Binding ThumbColor}" /></Border.Background>
                                                    </Border>
                                                    <Border Grid.Row="0" Grid.Column="1" Width="9" Height="9" CornerRadius="4.5">
                                                        <Border.Background><SolidColorBrush Color="{Binding TrackFillColor}" /></Border.Background>
                                                    </Border>
                                                    <Border Grid.Row="1" Grid.Column="0" Width="9" Height="9" CornerRadius="4.5">
                                                        <Border.Background><SolidColorBrush Color="{Binding TrackBackgroundColor}" /></Border.Background>
                                                    </Border>
                                                    <Border Grid.Row="1" Grid.Column="1" Width="9" Height="9" CornerRadius="4.5">
                                                        <Border.Background><SolidColorBrush Color="{Binding PeakMeterColor}" /></Border.Background>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                           FontSize="12" FontWeight="Medium"
                                                           Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                                <!-- Delete icon -->
                                                <Border Width="18" Height="18" CornerRadius="9" Margin="8,0,0,0"
                                                        Background="#20FF4444" Cursor="Hand"
                                                        MouseLeftButtonDown="DeleteCustomTheme_Click" Tag="{Binding}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#50FF4444" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="#FF6666" />
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Save current as new theme — compact inline -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Grid Width="160" Height="30">
                                    <TextBox Padding="6,4" FontSize="12"
                                             Text="{Binding NewThemeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#15FFFFFF" Foreground="White" BorderBrush="#30FFFFFF"
                                             x:Name="ThemeNameBox" />
                                    <TextBlock Text="Theme name..." FontSize="12" Padding="8,6" IsHitTestVisible="False"
                                               Foreground="#50FFFFFF" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=ThemeNameBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <Border Height="30" Margin="8,0,0,0" CornerRadius="6" Cursor="Hand" Padding="12,0"
                                        Background="#20FFFFFF" BorderThickness="1" BorderBrush="#25FFFFFF"
                                        MouseLeftButtonDown="SaveCustomTheme_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#30FFFFFF" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE105;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#7ED321" />
                                        <TextBlock Text="Save" FontSize="12" VerticalAlignment="Center"
                                                   Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Dynamic Album Art Theme -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window"
                            IsEnabled="{Binding UseCustomSliderColors}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Dynamic Theme" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Slider colors adapt to album art of playing music"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                            <CheckBox Content="Enable dynamic album art colors"
                                      IsChecked="{Binding UseDynamicAlbumArtTheme, Mode=TwoWay}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Custom Colors -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window"
                            IsEnabled="{Binding UseCustomSliderColors}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xE2B1;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Custom Colors" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Click a color to edit"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Slider Color Swatches -->
                            <TextBlock Text="Slider Colors" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"
                                       Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Thumb Color -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="Thumb">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderThickness" Value="3" />
                                                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding SliderThumbColor}" />
                                        </Border.Background>
                                        <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                    </Border>
                                    <TextBlock Text="Thumb" FontSize="11" Margin="0,6,0,0" FontWeight="Medium"
                                               HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                </StackPanel>

                                <!-- Fill Color -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="TrackFill">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderThickness" Value="3" />
                                                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding SliderTrackFillColor}" />
                                        </Border.Background>
                                        <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                    </Border>
                                    <TextBlock Text="Fill" FontSize="11" Margin="0,6,0,0" FontWeight="Medium"
                                               HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                </StackPanel>

                                <!-- Background Color -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="TrackBackground">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderThickness" Value="3" />
                                                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding SliderTrackBackgroundColor}" />
                                        </Border.Background>
                                        <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                    </Border>
                                    <TextBlock Text="Track BG" FontSize="11" Margin="0,6,0,0" FontWeight="Medium"
                                               HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                </StackPanel>

                                <!-- Peak Meter Color -->
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="PeakMeter">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderThickness" Value="3" />
                                                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding PeakMeterColor}" />
                                        </Border.Background>
                                        <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                    </Border>
                                    <TextBlock Text="Peak Meter" FontSize="11" Margin="0,6,0,0" FontWeight="Medium"
                                               HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                </StackPanel>
                            </Grid>

                            <!-- Window Theme Colors -->
                            <TextBlock Text="Window Colors" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,8"
                                       Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Window Background -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="WindowBackground">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderThickness" Value="3" />
                                                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding WindowBackgroundColor}" />
                                        </Border.Background>
                                        <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                    </Border>
                                    <TextBlock Text="Window BG" FontSize="11" Margin="0,6,0,0" FontWeight="Medium"
                                               HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                </StackPanel>

                                <!-- Text Color -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="TextColor">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderThickness" Value="3" />
                                                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding TextColorValue}" />
                                        </Border.Background>
                                        <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                    </Border>
                                    <TextBlock Text="Text" FontSize="11" Margin="0,6,0,0" FontWeight="Medium"
                                               HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                </StackPanel>

                                <!-- Accent Glow -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <Border Width="56" Height="56" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonDown="ColorBox_MouseLeftButtonDown" Tag="AccentGlow">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderThickness" Value="3" />
                                                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding AccentGlowColor}" />
                                        </Border.Background>
                                        <Border CornerRadius="10" BorderThickness="1" BorderBrush="#20FFFFFF" Margin="2" />
                                    </Border>
                                    <TextBlock Text="Glow" FontSize="11" Margin="0,6,0,0" FontWeight="Medium"
                                               HorizontalAlignment="Center" Style="{StaticResource BodySubText}" />
                                </StackPanel>
                            </Grid>

                            <!-- Styled Reset Button -->
                            <Border Height="36" HorizontalAlignment="Left" CornerRadius="6" Cursor="Hand"
                                    Background="#15FFFFFF" BorderThickness="1" BorderBrush="#20FFFFFF"
                                    MouseLeftButtonDown="ResetButton_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#25FFFFFF" />
                                                <Setter Property="BorderBrush" Value="#35FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                    <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,10,0"
                                               Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                    <TextBlock Text="Reset to Default" FontSize="13" VerticalAlignment="Center"
                                               Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:EarTrumpetLegacySettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                <!-- Startup -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="#15FFFFFF">
                                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Startup" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Launch BetterTrumpet with Windows"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <CheckBox HorizontalAlignment="Left"
                                  Content="Run at Windows startup"
                                  IsChecked="{Binding RunAtStartup, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <!-- Tray Icon -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                    Background="#15FFFFFF">
                                <TextBlock Text="&#xE825;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Tray Icon" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="System tray icon appearance"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <CheckBox HorizontalAlignment="Left"
                                  Content="{x:Static resx:Resources.SettingsUseLegacyEarTrumpetIcon}"
                                  IsChecked="{Binding UseLegacyIcon, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>

        <!-- Media Popup Settings Page -->
        <DataTemplate DataType="{x:Type vm:EarTrumpetMediaPopupSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                    <!-- SECTION: Enable Media Popup -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Media Popup" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Show media controls on tray hover"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox Content="Enable media popup"
                                      IsChecked="{Binding MediaPopupEnabled, Mode=TwoWay}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Interaction (merged Timing + Behavior) -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window"
                            IsEnabled="{Binding MediaPopupEnabled}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Interaction" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Hover delay and trigger behavior"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Hover delay slider -->
                            <TextBlock Text="Hover delay" FontSize="13" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="0.5s" Style="{StaticResource BodySubText}"
                                           VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Slider Grid.Column="1" Minimum="0.5" Maximum="5"
                                        Value="{Binding HoverDelay, Mode=TwoWay}"
                                        SmallChange="0.01" LargeChange="0.1" IsSnapToTickEnabled="False" />
                                <TextBlock Grid.Column="2" Text="5s" Style="{StaticResource BodySubText}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <Border Grid.Column="3" Padding="8,4" CornerRadius="6" Background="#20FFFFFF"
                                        HorizontalAlignment="Right" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding HoverDelayText}" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" FontSize="13" />
                                </Border>
                            </Grid>

                            <!-- Separator -->
                            <Border Height="1" Background="#10FFFFFF" Margin="0,0,0,14" />

                            <!-- Behavior options -->
                            <CheckBox Content="Only show when media is playing"
                                      IsChecked="{Binding ShowOnlyWhenPlaying, Mode=TwoWay}" Margin="0,0,0,8" />
                            <CheckBox Content="Remember expanded/collapsed state"
                                      IsChecked="{Binding RememberExpanded, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Visual Effects + Preview -->
                    <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                            Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window"
                            IsEnabled="{Binding MediaPopupEnabled}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                        Background="#15FFFFFF">
                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Visual Effects" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Album art blur intensity"
                                               Style="{StaticResource BodySubText}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Live preview of blur effect -->
                            <Border CornerRadius="8" Height="80" Margin="0,0,0,16"
                                    ClipToBounds="True" Background="#20FFFFFF">
                                <Grid>
                                    <!-- Simulated album art background with blur -->
                                    <Border CornerRadius="8">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF6B4E9B" Offset="0"/>
                                                <GradientStop Color="#FF2E86AB" Offset="0.5"/>
                                                <GradientStop Color="#FFA23B72" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <BlurEffect Radius="{Binding BlurRadius}" />
                                        </Border.Effect>
                                    </Border>
                                    <!-- Overlay content preview -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.9">
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                   HorizontalAlignment="Center" Foreground="White" />
                                        <TextBlock Text="Preview" FontSize="11" HorizontalAlignment="Center"
                                                   Foreground="White" Opacity="0.7" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Blur slider -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="None" Style="{StaticResource BodySubText}"
                                           VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Slider Grid.Column="1" Minimum="0" Maximum="30"
                                        Value="{Binding BlurRadius, Mode=TwoWay}"
                                        SmallChange="1" LargeChange="5" IsSnapToTickEnabled="False" />
                                <TextBlock Grid.Column="2" Text="Max" Style="{StaticResource BodySubText}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <Border Grid.Column="3" Padding="8,4" CornerRadius="6" Background="#20FFFFFF"
                                        HorizontalAlignment="Right" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding BlurRadiusText}" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" FontSize="13" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

            </StackPanel>
        </DataTemplate>

        <!-- Volume Profiles Settings Page -->
        <DataTemplate DataType="{x:Type vm:EarTrumpetVolumeProfilesSettingsPageViewModel}">
            <StackPanel Orientation="Vertical" Margin="0,0,16,0">

                <!-- SECTION: Save Current Volumes -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource SectionIconBorder}">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Save Current Volumes" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Snapshot device and app volumes"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding NewProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,6" FontSize="13" VerticalContentAlignment="Center"
                                     Theme:Brush.Foreground="Theme=Text, HighContrast=Text"
                                     Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="BorderBrush" Value="#30FFFFFF" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="#60FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Border Grid.Column="1" Height="32" Margin="8,0,0,0" CornerRadius="6" Cursor="Hand" Padding="16,0"
                                    Background="#20FFFFFF" BorderThickness="1" BorderBrush="#30FFFFFF"
                                    MouseLeftButtonDown="SaveProfile_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#30FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                               Theme:Brush.Foreground="Theme=GrayText, HighContrast=Text" />
                                    <TextBlock Text="Save" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Theme:Brush.Foreground="Theme=Text, HighContrast=Text" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION: Saved Profiles -->
                <Border Margin="0,0,0,20" Padding="20" CornerRadius="10"
                        Theme:Brush.Background="Theme={Theme}ListLow, HighContrast=Window">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource SectionIconBorder}">
                                <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Saved Profiles" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Select a profile to apply or manage"
                                           Style="{StaticResource BodySubText}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Profile list -->
                        <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                 MaxHeight="200" Margin="0,8,0,0"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#80FFFFFF" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock FontSize="11" Foreground="#80FFFFFF">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} device(s) | {1}">
                                                        <Binding Path="Devices.Count" />
                                                        <Binding Path="CreatedAt" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,4" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="0,1">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Selected profile details -->
                        <TextBlock Text="{Binding SelectedProfileDetails}" FontSize="11" Foreground="#60FFFFFF"
                                   Margin="0,8,0,0" Visibility="{Binding HasSelectedProfile, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Border Style="{StaticResource ActionButtonBorder}" MouseLeftButtonDown="ApplyProfile_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0"
