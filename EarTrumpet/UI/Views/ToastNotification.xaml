<Window x:Class="EarTrumpet.UI.Views.ToastNotification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ToastNotification"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Border x:Name="ToastBorder"
            Background="#2B2B2B"
            BorderBrush="#3F3F46"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12"
            Margin="16"
            RenderTransformOrigin="0.5,0.5">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="20" ShadowDepth="4" Direction="270"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleTransform" ScaleX="0.8" ScaleY="0.8"/>
                <TranslateTransform x:Name="TranslateTransform" Y="20"/>
            </TransformGroup>
        </Border.RenderTransform>

        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="IconText"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="20"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
            <TextBlock x:Name="MessageText"
                       FontSize="13"
                       Foreground="White"
                       VerticalAlignment="Center"
                       MaxWidth="300"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>
