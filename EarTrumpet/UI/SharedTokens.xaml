<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:bcl="clr-namespace:System;assembly=mscorlib">

    <!-- ══════════════════════════════════════════════════════════════════
         BETTERTRUMPET SHARED DESIGN TOKENS v3.1
         Single source of truth for colors, spacing, typography.
         Used by: SettingsWindow, OnboardingWindow, ChangelogWindow, MediaPopupWindow
         ══════════════════════════════════════════════════════════════════ -->

    <!-- ═══ COLOR PALETTE ═══ -->

    <!-- Backgrounds — elevation scale (darker = lower) -->
    <Color x:Key="BT.Bg">#FF101014</Color>
    <Color x:Key="BT.Surface">#FF18181E</Color>
    <Color x:Key="BT.SurfaceHover">#FF1F2028</Color>
    <Color x:Key="BT.SurfaceSelected">#FF1A2030</Color>
    <Color x:Key="BT.SurfaceRaised">#FF202028</Color>

    <!-- Borders — alpha-white, adapts to any bg (visual-border-alpha-colors) -->
    <Color x:Key="BT.Stroke">#12FFFFFF</Color>
    <Color x:Key="BT.StrokeMid">#20FFFFFF</Color>
    <Color x:Key="BT.StrokeStrong">#35FFFFFF</Color>

    <!-- Interactive states -->
    <Color x:Key="BT.Hover">#1AFFFFFF</Color>
    <Color x:Key="BT.HoverBorder">#30FFFFFF</Color>
    <Color x:Key="BT.Pressed">#30FFFFFF</Color>
    <Color x:Key="BT.Selected">#25FFFFFF</Color>
    <Color x:Key="BT.SelectedBorder">#50FFFFFF</Color>

    <!-- Accent — blue only, used sparingly (design principle: single accent) -->
    <Color x:Key="BT.Accent">#FF3B9EFF</Color>
    <Color x:Key="BT.AccentHover">#FF5BB0FF</Color>
    <Color x:Key="BT.AccentDim">#253B9EFF</Color>
    <Color x:Key="BT.AccentSubtle">#153B9EFF</Color>

    <!-- Semantic colors -->
    <Color x:Key="BT.Warning">#FFFFA726</Color>
    <Color x:Key="BT.WarningDim">#25FFA726</Color>
    <Color x:Key="BT.Danger">#FFFF4444</Color>
    <Color x:Key="BT.DangerDim">#20FF4444</Color>
    <Color x:Key="BT.Success">#FF4CAF50</Color>

    <!-- ═══ TEXT HIERARCHY (T1/T2/T3 — 3 levels, no more) ═══ -->
    <!-- T1 = primary content (94% white)  -->
    <!-- T2 = secondary content (44% white) -->
    <!-- T3 = tertiary/disabled (25% white) -->
    <Color x:Key="BT.T1">#F0FFFFFF</Color>
    <Color x:Key="BT.T2">#70FFFFFF</Color>
    <Color x:Key="BT.T3">#40FFFFFF</Color>

    <!-- ═══ BRUSHES ═══ -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BT.BgBrush"              Color="{StaticResource BT.Bg}"/>
    <SolidColorBrush x:Key="BT.SurfaceBrush"         Color="{StaticResource BT.Surface}"/>
    <SolidColorBrush x:Key="BT.SurfaceHoverBrush"    Color="{StaticResource BT.SurfaceHover}"/>
    <SolidColorBrush x:Key="BT.SurfaceSelectedBrush" Color="{StaticResource BT.SurfaceSelected}"/>
    <SolidColorBrush x:Key="BT.SurfaceRaisedBrush"   Color="{StaticResource BT.SurfaceRaised}"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BT.StrokeBrush"       Color="{StaticResource BT.Stroke}"/>
    <SolidColorBrush x:Key="BT.StrokeMidBrush"    Color="{StaticResource BT.StrokeMid}"/>
    <SolidColorBrush x:Key="BT.StrokeStrongBrush" Color="{StaticResource BT.StrokeStrong}"/>

    <!-- Interactive -->
    <SolidColorBrush x:Key="BT.HoverBrush"         Color="{StaticResource BT.Hover}"/>
    <SolidColorBrush x:Key="BT.HoverBorderBrush"   Color="{StaticResource BT.HoverBorder}"/>
    <SolidColorBrush x:Key="BT.PressedBrush"       Color="{StaticResource BT.Pressed}"/>
    <SolidColorBrush x:Key="BT.SelectedBrush"      Color="{StaticResource BT.Selected}"/>
    <SolidColorBrush x:Key="BT.SelectedBorderBrush" Color="{StaticResource BT.SelectedBorder}"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="BT.AccentBrush"    Color="{StaticResource BT.Accent}"/>
    <SolidColorBrush x:Key="BT.AccentHoverBrush" Color="{StaticResource BT.AccentHover}"/>
    <SolidColorBrush x:Key="BT.AccentDimBrush" Color="{StaticResource BT.AccentDim}"/>
    <SolidColorBrush x:Key="BT.AccentSubtleBrush" Color="{StaticResource BT.AccentSubtle}"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="BT.WarningBrush"    Color="{StaticResource BT.Warning}"/>
    <SolidColorBrush x:Key="BT.WarningDimBrush" Color="{StaticResource BT.WarningDim}"/>
    <SolidColorBrush x:Key="BT.DangerBrush"     Color="{StaticResource BT.Danger}"/>
    <SolidColorBrush x:Key="BT.DangerDimBrush"  Color="{StaticResource BT.DangerDim}"/>
    <SolidColorBrush x:Key="BT.SuccessBrush"    Color="{StaticResource BT.Success}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="BT.T1Brush" Color="{StaticResource BT.T1}"/>
    <SolidColorBrush x:Key="BT.T2Brush" Color="{StaticResource BT.T2}"/>
    <SolidColorBrush x:Key="BT.T3Brush" Color="{StaticResource BT.T3}"/>

    <!-- ═══ SPACING SCALE (4px base, geometric) ═══ -->
    <!-- Use these values everywhere. No arbitrary numbers. -->
    <bcl:Double x:Key="BT.Space.1">4</bcl:Double>
    <bcl:Double x:Key="BT.Space.2">8</bcl:Double>
    <bcl:Double x:Key="BT.Space.3">12</bcl:Double>
    <bcl:Double x:Key="BT.Space.4">16</bcl:Double>
    <bcl:Double x:Key="BT.Space.5">24</bcl:Double>
    <bcl:Double x:Key="BT.Space.6">32</bcl:Double>
    <bcl:Double x:Key="BT.Space.7">48</bcl:Double>

    <!-- ═══ RADIUS SCALE ═══ -->
    <!-- visual-concentric-radius: inner = outer - padding -->
    <CornerRadius x:Key="BT.Radius.SM">6</CornerRadius>
    <CornerRadius x:Key="BT.Radius.MD">8</CornerRadius>
    <CornerRadius x:Key="BT.Radius.LG">10</CornerRadius>
    <CornerRadius x:Key="BT.Radius.XL">14</CornerRadius>

    <!-- ═══ TYPOGRAPHY SCALE (5 levels max) ═══ -->
    <!-- H1: Page title  -->
    <bcl:Double x:Key="BT.FontSize.H1">26</bcl:Double>
    <!-- H2: Section title -->
    <bcl:Double x:Key="BT.FontSize.H2">15</bcl:Double>
    <!-- Body: Default text, labels -->
    <bcl:Double x:Key="BT.FontSize.Body">13</bcl:Double>
    <!-- Caption: Descriptions, hints -->
    <bcl:Double x:Key="BT.FontSize.Caption">12</bcl:Double>
    <!-- Micro: Badges, tiny labels -->
    <bcl:Double x:Key="BT.FontSize.Micro">10</bcl:Double>

    <!-- ═══ ANIMATION TIMING ═══ -->
    <!-- timing-under-300ms: all user-initiated under 300ms -->
    <!-- duration-small-state: 180-260ms for state changes -->
    <!-- duration-press-hover: 120-180ms for press/hover -->
    <Duration x:Key="BT.Anim.Instant">0:0:0.0</Duration>
    <Duration x:Key="BT.Anim.Micro">0:0:0.12</Duration>
    <Duration x:Key="BT.Anim.Fast">0:0:0.18</Duration>
    <Duration x:Key="BT.Anim.Default">0:0:0.22</Duration>
    <Duration x:Key="BT.Anim.Slow">0:0:0.30</Duration>

    <!-- ═══ GLOBAL STYLES ═══ -->

    <!-- Section icon container — concentric radius with Padding=20 card -->
    <!-- visual-concentric-radius: card CornerRadius=10, pad=20 → icon = 8 -->
    <Style x:Key="BT.SectionIcon" TargetType="Border">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="CornerRadius" Value="{StaticResource BT.Radius.MD}"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="Background" Value="{StaticResource BT.SurfaceBrush}"/>
    </Style>

    <!-- Section card — main container for a settings group -->
    <Style x:Key="BT.SectionCard" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,20"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="CornerRadius" Value="{StaticResource BT.Radius.LG}"/>
        <Setter Property="Background" Value="{StaticResource BT.SurfaceBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BT.StrokeBrush}"/>
    </Style>

    <!-- Action button — unified hover + press states -->
    <!-- physics-active-state: scale on press -->
    <Style x:Key="BT.ActionButton" TargetType="Border">
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="{StaticResource BT.Radius.SM}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="Background" Value="{StaticResource BT.SurfaceBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BT.StrokeMidBrush}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BT.HoverBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BT.HoverBorderBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Separator line — 1px alpha-white -->
    <Style x:Key="BT.Separator" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource BT.StrokeBrush}"/>
        <Setter Property="Margin" Value="0,12,0,12"/>
    </Style>

    <!-- Warning banner — amber background -->
    <Style x:Key="BT.WarningBanner" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BT.WarningDimBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource BT.Radius.MD}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

</ResourceDictionary>
